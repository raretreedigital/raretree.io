---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 10 10M22 2l-5 5M17 2h5v5"/><circle cx="12" cy="12" r="3"/><path d="M12 9V7M12 17v-2M9 12H7M17 12h-2"/></svg>`,
    title: "AI Integration & Automation",
    desc: "Custom AI-powered workflows plugged directly into your existing systems — no rip-and-replace required. We identify your highest-ROI automation opportunities and build intelligent pipelines that run 24/7.",
    features: ["Custom n8n / Zapier Workflows", "LLM Integration (GPT-4, Claude)", "Data Pipeline Automation", "API Integrations", "Real-time Monitoring & Alerts"],
    tag: "Most Popular",
    accent: "#14b8a6",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>`,
    title: "Email Marketing",
    desc: "Reach inboxes. Drive revenue. Build loyalty. We design personalized, automated email campaigns backed by behavioral triggers and audience insights that convert at scale.",
    features: ["Campaign Strategy & Creative Design", "Automation & Drip Sequences", "A/B Testing for Optimal Performance", "List Management & Segmentation", "Performance Tracking & Optimization"],
    tag: "High ROI",
    accent: "#8b5cf6",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 5-5"/></svg>`,
    title: "Campaign Analytics",
    desc: "From data to direction. Our analytics solutions provide actionable dashboards and insights that fuel performance, maximize budget efficiency, and guide strategic decisions.",
    features: ["Multi-channel Tracking (Google, Meta, CRM)", "Conversion Funnel Analysis", "Dashboards & Reporting Automation", "ROI Modeling & Attribution", "Strategic Data Recommendations"],
    tag: "Data-Driven",
    accent: "#06b6d4",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`,
    title: "Digital Marketing",
    desc: "Integrated campaigns that build awareness, generate qualified leads, and convert traffic into paying customers through SEO, PPC, social, and content marketing.",
    features: ["Search Engine Optimization (SEO)", "Paid Search (SEM / PPC)", "Social Media Marketing", "Content Planning, Creation & Scheduling", "Influencer Outreach & Collaboration"],
    tag: "Full-Stack",
    accent: "#f59e0b",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: "Digital Commerce (Shopify)",
    desc: "From browsing to buying — we build Shopify stores optimized for mobile, UX, and checkout performance that make every product page a conversion machine.",
    features: ["Shopify Store Setup & Custom Development", "Mobile-Optimized UX & UI", "Product Page Optimization", "Checkout & Payment Integration", "Conversion Rate Optimization (CRO)"],
    tag: "E-Commerce",
    accent: "#10b981",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Digital Business Transformation",
    desc: "Modern businesses need agile, tech-driven models. We guide organizations into the digital age, aligning tools and workflows with real business outcomes — fast.",
    features: ["Business Process Automation", "CRM and ERP Implementation", "Digital Strategy Consulting", "Legacy System Modernization", "Team Enablement & Training"],
    tag: "Enterprise",
    accent: "#ef4444",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`,
    title: "Lead Generation Systems",
    desc: "AI-driven outbound and inbound funnels that consistently deliver qualified leads — CRM automations, targeted prospecting, and multi-channel nurture sequences.",
    features: ["AI-Powered Prospecting", "CRM Automation (HubSpot, Salesforce)", "Multi-channel Nurture Sequences", "Lead Scoring & Qualification", "Funnel Analytics & Optimization"],
    tag: "Revenue Growth",
    accent: "#14b8a6",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 19 21 12 17 5 21 12 2"/></svg>`,
    title: "Digital Ads & Event Marketing",
    desc: "From product launches to conferences — we ensure your events and campaigns are seen by the right people at precisely the right time, maximizing attendance and conversions.",
    features: ["Social Media Advertising (Meta, LinkedIn)", "Google Ads & Retargeting", "Event Microsite / Landing Page Design", "RSVP & Lead Capture Funnels", "Real-time Performance Monitoring"],
    tag: "Ads & Events",
    accent: "#8b5cf6",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`,
    title: "AI & ML Development",
    desc: "Production-grade artificial intelligence and machine learning systems — from custom LLM fine-tuning and RAG pipelines to computer vision, predictive analytics, and intelligent chatbots.",
    features: ["Custom LLM Fine-tuning (Llama, Mistral)", "RAG Pipelines & Vector DBs", "Computer Vision & Image Recognition", "Predictive Analytics & Forecasting", "AI Chatbots & Agent Systems"],
    tag: "Next-Gen AI",
    accent: "#a855f7",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v3m0 3h.01"/></svg>`,
    title: "SEO Optimization",
    desc: "Dominate search rankings with technical SEO, high-authority link building, content strategy, and Core Web Vitals optimization that compounds your organic traffic month over month.",
    features: ["Technical SEO Audit & Fixes", "Keyword Research & Content Strategy", "Core Web Vitals Optimization", "High-Authority Link Building", "Local SEO & Google Business Profile"],
    tag: "Rank #1",
    accent: "#f59e0b",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: "Branding & Creative Marketing",
    desc: "Iconic brand identities, compelling visual storytelling, and creative campaigns that make your brand unmissable — from logo design to full brand systems and content production.",
    features: ["Logo & Brand Identity Design", "Brand Guidelines & Style System", "Social Media Creative Production", "Copywriting & Brand Messaging", "Video & Motion Content"],
    tag: "Creative",
    accent: "#ec4899",
  },
];
---

<Layout title="Services | Raretree Digital">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-orb orb-a"></div>
    <div class="page-hero-orb orb-b"></div>
    <div class="container">
      <div class="page-hero-content">
        <span class="section-eyebrow reveal">What We Offer</span>
        <h1 class="page-hero-title reveal delay-1">
          Services Built for<br/>
          <span class="gradient-text">Serious Growth</span>
        </h1>
        <p class="page-hero-sub reveal delay-2">
          From AI automation to full-scale digital campaigns — every service is designed to deliver measurable, compounding returns.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="section services-list">
    <div class="container">
      <div class="services-grid">
        {services.map((s, i) => (
          <div class={`service-card reveal delay-${(i % 3) + 1}`} style={`--s-accent: ${s.accent}`}>
            <div class="service-card-top">
              <div class="service-icon" set:html={s.icon}></div>
              <span class="service-tag">{s.tag}</span>
            </div>
            <h3 class="service-title">{s.title}</h3>
            <p class="service-desc">{s.desc}</p>
            <ul class="service-features">
              {s.features.map(f => (
                <li>
                  <span class="check-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class="service-cta">
              Get Started
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="section comparison-section">
    <div class="container container-sm">
      <div class="section-header">
        <span class="section-eyebrow reveal">Why Raretree</span>
        <h2 class="section-title reveal delay-1">We're <span class="gradient-text">Different</span></h2>
      </div>
      <div class="comparison-table reveal delay-2">
        <div class="comp-row comp-header">
          <div class="comp-cell">Feature</div>
          <div class="comp-cell comp-ours">Raretree</div>
          <div class="comp-cell">Typical Agency</div>
        </div>
        {[
          ["Dedicated automation engineers", "✓", "✗"],
          ["AI-native workflow design", "✓", "Rarely"],
          ["Real-time analytics dashboards", "✓", "Monthly reports"],
          ["Full-stack (strategy + execution)", "✓", "Siloed"],
          ["Transparent pricing", "✓", "Hidden fees"],
          ["Dedicated account manager", "✓", "Shared"],
          ["Guaranteed response time", "< 4 hours", "1-3 days"],
        ].map(([feat, ours, them]) => (
          <div class="comp-row">
            <div class="comp-cell comp-feat">{feat}</div>
            <div class="comp-cell comp-ours comp-yes">{ours}</div>
            <div class="comp-cell comp-no">{them}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta section">
    <div class="container">
      <div class="cta-box reveal-scale">
        <h2>Ready to Get <span class="gradient-text">Started?</span></h2>
        <p>Book a 30-minute strategy call. Zero commitment. Just clarity.</p>
        <a href="/contact" class="btn btn-primary btn-lg">Book Free Strategy Call</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 120px 0 80px;
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse at 50% 0%, #0d1b2a 0%, #030712 70%);
  }

  .page-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .orb-a {
    width: 500px; height: 400px;
    background: radial-gradient(circle, rgba(20,184,166,0.18) 0%, transparent 70%);
    top: -100px; left: -100px;
    animation: floatOrb 10s ease-in-out infinite;
  }

  .orb-b {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(139,92,246,0.14) 0%, transparent 70%);
    top: 0; right: -100px;
    animation: floatOrb 13s ease-in-out infinite 3s;
  }

  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }

  .page-hero-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .page-hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    color: #f1f5f9;
    margin: 14px 0 20px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .page-hero-sub {
    font-size: 1.1rem;
    color: #94a3b8;
    line-height: 1.75;
  }

  /* SERVICES GRID */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(148, 163, 184, 0.08);
    border-radius: 20px;
    padding: 32px;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--s-accent), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .service-card:hover {
    border-color: rgba(148, 163, 184, 0.16);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .service-icon {
    width: 44px;
    height: 44px;
    color: var(--s-accent);
    flex-shrink: 0;
  }

  .service-icon svg {
    width: 100%;
    height: 100%;
  }

  .service-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--s-accent);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 4px 10px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .service-title {
    font-size: 1.08rem;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1.3;
  }

  .service-desc {
    font-size: 0.88rem;
    color: #94a3b8;
    line-height: 1.7;
    flex: 1;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .service-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.84rem;
    color: #64748b;
    line-height: 1.4;
  }

  .check-icon {
    width: 18px;
    height: 18px;
    background: rgba(20, 184, 166, 0.12);
    border: 1px solid rgba(20, 184, 166, 0.25);
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #14b8a6;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--s-accent);
    margin-top: 4px;
    transition: gap 0.2s ease;
  }

  .service-cta:hover { gap: 12px; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  /* COMPARISON TABLE */
  .comparison-table {
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 16px;
    overflow: hidden;
  }

  .comp-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    border-bottom: 1px solid rgba(148, 163, 184, 0.06);
  }

  .comp-row:last-child { border-bottom: none; }

  .comp-header {
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
  }

  .comp-cell {
    padding: 16px 20px;
    font-size: 0.88rem;
    color: #64748b;
    display: flex;
    align-items: center;
  }

  .comp-header .comp-cell {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
  }

  .comp-ours {
    background: rgba(20, 184, 166, 0.04);
    border-left: 1px solid rgba(20, 184, 166, 0.12);
    border-right: 1px solid rgba(20, 184, 166, 0.12);
  }

  .comp-header .comp-ours {
    color: #14b8a6 !important;
    font-weight: 800 !important;
  }

  .comp-feat { color: #94a3b8; font-weight: 500; }
  .comp-yes { color: #14b8a6 !important; font-weight: 700; }
  .comp-no { color: #475569; }

  @media (max-width: 600px) {
    .comp-cell { padding: 12px 14px; font-size: 0.8rem; }
  }

  /* CTA BOX */
  .cta-box {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(20, 184, 166, 0.15);
    border-radius: 24px;
    padding: 72px 48px;
    text-align: center;
    backdrop-filter: blur(16px);
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-box h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    color: #f1f5f9;
    margin-bottom: 16px;
  }

  .cta-box p {
    color: #94a3b8;
    margin-bottom: 36px;
    font-size: 1rem;
  }

  @media (max-width: 600px) {
    .cta-box { padding: 48px 28px; }
  }
</style>

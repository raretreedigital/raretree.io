---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Raretree Digital — AI Automation & Digital Transformation Agency"
  description="Raretree Digital helps businesses scale with AI automation, custom web & mobile apps, CRM/ERP implementation, and data-driven growth marketing. Book a free call today."
  keywords="AI automation agency, digital transformation, web app development, mobile app development, CRM implementation, growth marketing, Zoho partner, Salesforce partner"
  url="https://raretree.io/"
>

  <!-- ====== HERO ====== -->
  <section class="hero">
    <!-- Animated background orbs -->
    <div class="hero-orb orb-1"></div>
    <div class="hero-orb orb-2"></div>
    <div class="hero-orb orb-3"></div>
    <!-- Animated grid -->
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-content container">
      <div class="hero-badge reveal">
        <span class="badge badge-teal">
          <span class="badge-dot"></span>
          AI-Powered Automation Agency
        </span>
      </div>
      <h1 class="hero-title reveal delay-1">
        We Build Systems That<br/>
        <span class="gradient-text">Scale Your Business</span><br/>
        on Autopilot
      </h1>
      <p class="hero-subtitle reveal delay-2">
        Raretree Digital designs intelligent automation workflows, growth systems,
        and digital strategies that slash costs, amplify efficiency, and drive
        predictable revenue.
      </p>
      <div class="hero-actions reveal delay-3">
        <a href="/contact" class="btn btn-primary btn-lg">
          Book a Strategy Call
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/services" class="btn btn-secondary btn-lg">
          Explore Services
        </a>
      </div>
      <div class="hero-stats reveal delay-4">
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="50">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Projects</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="30">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Clients</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="95">0</span><span class="hero-stat-num">%</span>
          <span class="hero-stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- 3D Floating Shapes -->
    <div class="hero-3d-shapes">
      <div class="shape-wrapper shape-cube-1" data-interactive="true">
        <div class="cube3d">
          <div class="cube3d-face front"></div><div class="cube3d-face back"></div>
          <div class="cube3d-face left"></div><div class="cube3d-face right"></div>
          <div class="cube3d-face top"></div><div class="cube3d-face bottom"></div>
        </div>
      </div>
      <div class="shape-wrapper shape-cube-2" data-interactive="true">
        <div class="cube3d cube3d-sm">
          <div class="cube3d-face front"></div><div class="cube3d-face back"></div>
          <div class="cube3d-face left"></div><div class="cube3d-face right"></div>
          <div class="cube3d-face top"></div><div class="cube3d-face bottom"></div>
        </div>
      </div>
      <div class="shape-wrapper shape-cube-3" data-interactive="true">
        <div class="cube3d cube3d-xs">
          <div class="cube3d-face front"></div><div class="cube3d-face back"></div>
          <div class="cube3d-face left"></div><div class="cube3d-face right"></div>
          <div class="cube3d-face top"></div><div class="cube3d-face bottom"></div>
        </div>
      </div>
      <div class="shape-wrapper shape-ring-1" data-interactive="true"><div class="ring3d"></div></div>
      <div class="shape-wrapper shape-ring-2" data-interactive="true"><div class="ring3d ring3d-sm"></div></div>
      <div class="shape-wrapper shape-ring-3" data-interactive="true"><div class="ring3d ring3d-lg"></div></div>
      <div class="shape-wrapper shape-diamond-1" data-interactive="true"><div class="diamond3d"></div></div>
      <div class="shape-wrapper shape-diamond-2" data-interactive="true"><div class="diamond3d diamond3d-purple"></div></div>
      <div class="shape-wrapper shape-icosa-1" data-interactive="true"><div class="icosa3d"></div></div>
      <div class="shape-wrapper shape-pyramid-1" data-interactive="true">
        <svg class="shape-svg-pyramid" viewBox="0 0 100 100" fill="none">
          <polygon points="50,5 95,85 5,85" stroke="rgba(6,214,196,0.45)" stroke-width="1.2" fill="rgba(6,214,196,0.03)"/>
          <polygon points="50,5 95,85 50,55" stroke="rgba(6,214,196,0.25)" stroke-width="0.8" fill="rgba(6,214,196,0.02)"/>
          <polygon points="50,5 5,85 50,55" stroke="rgba(168,85,247,0.25)" stroke-width="0.8" fill="rgba(168,85,247,0.02)"/>
        </svg>
      </div>
      <div class="shape-wrapper shape-hex-1" data-interactive="true">
        <svg class="shape-svg-hex" viewBox="0 0 100 100" fill="none">
          <polygon points="50,5 90,27.5 90,72.5 50,95 10,72.5 10,27.5" stroke="rgba(168,85,247,0.4)" stroke-width="1" fill="rgba(168,85,247,0.03)"/>
          <polygon points="50,18 77,33 77,67 50,82 23,67 23,33" stroke="rgba(168,85,247,0.2)" stroke-width="0.7" fill="none"/>
        </svg>
      </div>

      <!-- NEW SHAPES -->
      <div class="shape-wrapper shape-torus-1" data-interactive="true">
        <svg class="shape-svg-torus" viewBox="0 0 130 70" fill="none">
          <ellipse cx="65" cy="35" rx="56" ry="28" stroke="rgba(6,214,196,0.5)" stroke-width="1.1"/>
          <ellipse cx="65" cy="35" rx="34" ry="14" stroke="rgba(6,214,196,0.22)" stroke-width="0.7"/>
          <ellipse cx="42" cy="35" rx="12" ry="28" stroke="rgba(168,85,247,0.32)" stroke-width="0.8"/>
          <ellipse cx="88" cy="35" rx="12" ry="28" stroke="rgba(168,85,247,0.32)" stroke-width="0.8"/>
          <ellipse cx="65" cy="35" rx="56" ry="10" stroke="rgba(6,214,196,0.12)" stroke-width="0.5"/>
          <ellipse cx="65" cy="35" rx="22" ry="28" stroke="rgba(99,179,255,0.18)" stroke-width="0.5" stroke-dasharray="4 4"/>
        </svg>
      </div>
      <div class="shape-wrapper shape-dna-1" data-interactive="true">
        <svg class="shape-svg-dna" viewBox="0 0 44 130" fill="none">
          <path d="M6 0 Q38 16 6 32 Q-26 48 6 64 Q38 80 6 96 Q-26 112 6 128" stroke="rgba(6,214,196,0.6)" stroke-width="1.6" fill="none"/>
          <path d="M38 0 Q6 16 38 32 Q70 48 38 64 Q6 80 38 96 Q70 112 38 128" stroke="rgba(168,85,247,0.6)" stroke-width="1.6" fill="none"/>
          <line x1="6" y1="16" x2="38" y2="16" stroke="rgba(99,179,255,0.4)" stroke-width="1"/>
          <line x1="6" y1="48" x2="38" y2="48" stroke="rgba(99,179,255,0.4)" stroke-width="1"/>
          <line x1="6" y1="80" x2="38" y2="80" stroke="rgba(99,179,255,0.4)" stroke-width="1"/>
          <line x1="6" y1="112" x2="38" y2="112" stroke="rgba(99,179,255,0.4)" stroke-width="1"/>
          <circle cx="6" cy="16" r="2.5" fill="rgba(6,214,196,0.7)"/>
          <circle cx="38" cy="16" r="2.5" fill="rgba(168,85,247,0.7)"/>
          <circle cx="6" cy="48" r="2.5" fill="rgba(6,214,196,0.7)"/>
          <circle cx="38" cy="48" r="2.5" fill="rgba(168,85,247,0.7)"/>
          <circle cx="6" cy="80" r="2.5" fill="rgba(6,214,196,0.7)"/>
          <circle cx="38" cy="80" r="2.5" fill="rgba(168,85,247,0.7)"/>
          <circle cx="6" cy="112" r="2.5" fill="rgba(6,214,196,0.7)"/>
          <circle cx="38" cy="112" r="2.5" fill="rgba(168,85,247,0.7)"/>
        </svg>
      </div>
      <div class="shape-wrapper shape-wave-1" data-interactive="true">
        <svg class="shape-svg-wave" viewBox="0 0 140 55" fill="none">
          <path d="M0 27 Q17 8 35 27 Q53 46 70 27 Q87 8 105 27 Q123 46 140 27" stroke="rgba(6,214,196,0.45)" stroke-width="1.4" fill="none"/>
          <path d="M0 36 Q17 17 35 36 Q53 55 70 36 Q87 17 105 36 Q123 55 140 36" stroke="rgba(168,85,247,0.3)" stroke-width="0.9" fill="none"/>
          <path d="M0 18 Q17 0 35 18 Q53 36 70 18 Q87 0 105 18 Q123 36 140 18" stroke="rgba(99,179,255,0.2)" stroke-width="0.6" fill="none"/>
        </svg>
      </div>
      <div class="shape-wrapper shape-octa-1" data-interactive="true">
        <svg class="shape-svg-octa" viewBox="0 0 90 90" fill="none">
          <polygon points="45,5 85,45 45,85 5,45" stroke="rgba(245,158,11,0.5)" stroke-width="1.1" fill="rgba(245,158,11,0.03)"/>
          <polygon points="45,22 68,45 45,68 22,45" stroke="rgba(255,90,90,0.38)" stroke-width="0.8" fill="rgba(255,90,90,0.02)"/>
          <line x1="45" y1="5" x2="45" y2="85" stroke="rgba(245,158,11,0.18)" stroke-width="0.5"/>
          <line x1="5" y1="45" x2="85" y2="45" stroke="rgba(245,158,11,0.18)" stroke-width="0.5"/>
          <circle cx="45" cy="5" r="2.5" fill="rgba(245,158,11,0.7)"/>
          <circle cx="85" cy="45" r="2.5" fill="rgba(245,158,11,0.7)"/>
          <circle cx="45" cy="85" r="2.5" fill="rgba(245,158,11,0.7)"/>
          <circle cx="5" cy="45" r="2.5" fill="rgba(245,158,11,0.7)"/>
        </svg>
      </div>
    </div>

    <!-- Holographic sphere — desktop interactive -->
    <div class="hero-hologram-wrap" aria-hidden="true">
      <div class="hero-hologram">
        <div class="holo-ring holo-r1"></div>
        <div class="holo-ring holo-r2"></div>
        <div class="holo-ring holo-r3"></div>
        <div class="holo-ring holo-r4"></div>
        <div class="holo-equator"></div>
        <div class="holo-meridian"></div>
        <div class="holo-core"></div>
        <div class="holo-glow"></div>
        <svg class="holo-grid" viewBox="0 0 200 200" fill="none">
          <circle cx="100" cy="100" r="90" stroke="rgba(6,214,196,0.18)" stroke-width="0.6"/>
          <circle cx="100" cy="100" r="70" stroke="rgba(6,214,196,0.12)" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="50" stroke="rgba(168,85,247,0.15)" stroke-width="0.5"/>
          <ellipse cx="100" cy="100" rx="90" ry="30" stroke="rgba(6,214,196,0.22)" stroke-width="0.7"/>
          <ellipse cx="100" cy="100" rx="90" ry="52" stroke="rgba(6,214,196,0.14)" stroke-width="0.5"/>
          <ellipse cx="100" cy="100" rx="90" ry="75" stroke="rgba(6,214,196,0.1)" stroke-width="0.4"/>
          <ellipse cx="100" cy="100" rx="30" ry="90" stroke="rgba(168,85,247,0.18)" stroke-width="0.6"/>
          <ellipse cx="100" cy="100" rx="52" ry="90" stroke="rgba(168,85,247,0.1)" stroke-width="0.4"/>
        </svg>
      </div>
    </div>

    <!-- Hero canvas animation -->
    <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  </section>

  <!-- ====== LOGOS / TRUSTED BY ====== -->
  <section class="trusted section-sm">
    <div class="container">
      <p class="trusted-label reveal">Trusted by growing businesses worldwide</p>
      <div class="trusted-track reveal delay-1">
        <div class="trusted-list">
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item">{name}</span>
          ))}
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item" aria-hidden="true">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== WHAT WE DO ====== -->
  <section class="section what-we-do">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">What We Do</span>
        <h2 class="section-title reveal delay-1">
          Full-Stack Digital <span class="gradient-text">Intelligence</span>
        </h2>
        <p class="section-subtitle reveal delay-2">
          We combine strategy, automation, and creative execution to build growth systems that work while you sleep.
        </p>
      </div>

      <!-- Platform Implementation trio (featured first) -->
      <div class="bento-platform-trio">
        <div class="bento-card bento-platform bento-whatsapp">
          <div class="bento-platform-orb"></div>
          <div class="bento-icon bento-icon-glow bento-icon-lg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              <circle cx="9" cy="10" r="1" fill="currentColor"/>
              <circle cx="12" cy="10" r="1" fill="currentColor"/>
              <circle cx="15" cy="10" r="1" fill="currentColor"/>
            </svg>
          </div>
          <div class="bento-platform-badge">Most Requested</div>
          <h3 class="bento-title">WhatsApp Business Automation</h3>
          <p class="bento-desc">Turn WhatsApp into your most powerful business channel. We set up the official API, build AI chatbots, broadcast campaigns, order notifications, and full CRM integration — so you sell and support where your customers already live.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#25d366;border-color:rgba(37,211,102,0.3);background:rgba(37,211,102,0.08)">WhatsApp API</span>
            <span class="tag" style="color:#25d366;border-color:rgba(37,211,102,0.3);background:rgba(37,211,102,0.08)">AI Chatbot</span>
            <span class="tag" style="color:#25d366;border-color:rgba(37,211,102,0.3);background:rgba(37,211,102,0.08)">Broadcasts</span>
          </div>
          <a href="/services" class="bento-link" style="color:#25d366">
            See how it works
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="bento-card bento-platform bento-zoho">
          <div class="bento-platform-orb"></div>
          <div class="bento-icon bento-icon-glow bento-icon-lg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
              <line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
          </div>
          <div class="bento-platform-badge">Full Ecosystem</div>
          <h3 class="bento-title">Zoho Suite Implementation</h3>
          <p class="bento-desc">End-to-end Zoho deployment tailored to how your business actually runs — CRM, Books, Desk, Campaigns, People, Projects, and beyond, all connected in one unified platform.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#e8441a;border-color:rgba(232,68,26,0.3);background:rgba(232,68,26,0.08)">Zoho CRM</span>
            <span class="tag" style="color:#e8441a;border-color:rgba(232,68,26,0.3);background:rgba(232,68,26,0.08)">Zoho Books</span>
            <span class="tag" style="color:#e8441a;border-color:rgba(232,68,26,0.3);background:rgba(232,68,26,0.08)">Automations</span>
          </div>
          <a href="/services" class="bento-link" style="color:#e8441a">
            Explore Zoho
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="bento-card bento-platform bento-odoo">
          <div class="bento-platform-orb"></div>
          <div class="bento-icon bento-icon-glow bento-icon-lg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="bento-platform-badge">ERP / All-in-One</div>
          <h3 class="bento-title">Odoo ERP Implementation</h3>
          <p class="bento-desc">A truly integrated business OS — Sales, Inventory, Accounting, HR, Manufacturing, Website, and POS all in one. We deploy, customise, and integrate every Odoo module your business needs.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#a16207;border-color:rgba(113,75,103,0.35);background:rgba(113,75,103,0.1)">Odoo ERP</span>
            <span class="tag" style="color:#a16207;border-color:rgba(113,75,103,0.35);background:rgba(113,75,103,0.1)">Custom Modules</span>
            <span class="tag" style="color:#a16207;border-color:rgba(113,75,103,0.35);background:rgba(113,75,103,0.1)">Integrations</span>
          </div>
          <a href="/services" class="bento-link" style="color:#c4a000">
            Explore Odoo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="services-bento">
        <div class="bento-card bento-large reveal">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2a10 10 0 1 0 10 10M22 2l-5 5M17 2h5v5"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 9V7M12 17v-2M9 12H7M17 12h-2"/>
            </svg>
          </div>
          <h3 class="bento-title">AI Workflow Automation</h3>
          <p class="bento-desc">
            We map your operations, identify bottlenecks, and build intelligent automations that eliminate repetitive work, reduce errors, and scale your capacity — without adding headcount.
          </p>
          <div class="bento-tags">
            <span class="tag">n8n</span>
            <span class="tag">Zapier</span>
            <span class="tag">Custom AI</span>
            <span class="tag">LLMs</span>
          </div>
          <a href="/services" class="bento-link">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="bento-card reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 3v18h18"/>
              <path d="m7 16 4-4 4 4 5-5"/>
            </svg>
          </div>
          <h3 class="bento-title">Campaign Analytics</h3>
          <p class="bento-desc">From raw data to actionable insights — dashboards that tell you exactly where to invest and what's driving growth.</p>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="bento-title">Lead Generation</h3>
          <p class="bento-desc">AI-driven funnels, CRM automation, and targeted outreach systems that consistently deliver qualified leads at scale.</p>
        </div>

        <div class="bento-card bento-wide reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Commerce</h3>
          <p class="bento-desc">Mobile-optimized Shopify stores built for conversion — from product pages to checkout, every pixel earns its place.</p>
          <div class="bento-tags">
            <span class="tag">Shopify</span>
            <span class="tag">CRO</span>
            <span class="tag">UX/UI</span>
          </div>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="bento-title">Consulting & Strategy</h3>
          <p class="bento-desc">Deep-dive strategy sessions that align your tools, team, and technology with real business outcomes.</p>
        </div>

        <div class="bento-card bento-highlight reveal delay-3">
          <div class="bento-icon bento-icon-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Marketing</h3>
          <p class="bento-desc">SEO, PPC, social media — integrated campaigns that build awareness and convert traffic into revenue.</p>
          <div class="bento-tags">
            <span class="tag">SEO</span>
            <span class="tag">PPC</span>
            <span class="tag">Social</span>
          </div>
        </div>

        <div class="bento-card bento-large bento-ai-ml reveal delay-1">
          <div class="bento-ai-orb"></div>
          <div class="bento-icon bento-icon-glow" style="color:#a855f7">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
            </svg>
          </div>
          <h3 class="bento-title">AI & ML Development</h3>
          <p class="bento-desc">
            From custom LLM fine-tuning to computer vision and predictive models — we build production-grade AI systems that deliver real business intelligence.

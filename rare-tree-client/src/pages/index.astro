    .cap-grid { grid-template-columns: 1fr; }
  }

  /* ===== BENTO CARD SPOTLIGHT GLOW (cursor-tracking) ===== */
  .bento-card {
    --mx: 50%;
    --my: 50%;
  }
  .bento-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx) var(--my), rgba(6,214,196,0.11) 0%, transparent 52%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    border-radius: inherit;
    z-index: 0;
  }
  .bento-card:hover::before { opacity: 1; }
  .bento-card > * { position: relative; z-index: 1; }

  /* bento icon jolts on hover */
  .bento-card:hover .bento-icon svg {
    animation: iconJolt 0.45s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes iconJolt {
    0%   { transform: scale(1) rotate(0deg); }
    30%  { transform: scale(1.22) rotate(-10deg); }
    65%  { transform: scale(0.94) rotate(5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  /* ===== STAT CARD ENHANCED HOVER ===== */
  .stat-card:hover {
    border-color: rgba(6,214,196,0.28);
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 24px 64px rgba(0,0,0,0.45), 0 0 50px rgba(6,214,196,0.1);
  }
  .stat-card:hover .stat-number {
    color: #ffffff;
    text-shadow: 0 0 30px rgba(6,214,196,0.55), 0 0 70px rgba(6,214,196,0.2);
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .stat-card:hover .stat-icon {
    color: #06d6c4;
    opacity: 1;
    animation: statIconSpin 0.65s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes statIconSpin {
    0%   { transform: rotate(0deg) scale(1); }
    45%  { transform: rotate(200deg) scale(1.25); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ===== PROCESS STEP HOVER ===== */
  .process-step {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .process-step:hover {
    transform: translateX(10px);
  }
  .process-num {
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .process-step:hover .process-num {
    color: rgba(6,214,196,0.75);
    text-shadow: 0 0 32px rgba(6,214,196,0.45);
  }
  .process-body h3 {
    transition: color 0.3s ease;
  }
  .process-step:hover .process-body h3 {
    color: #06d6c4;
  }

  /* ===== TESTIMONIAL CARD — disable translateY to let JS tilt take over ===== */
  .testimonial-card {
    transform-style: preserve-3d;
    will-change: transform;
    transition: border-color 0.3s ease, box-shadow 0.3s ease !important;
  }
  .testimonial-card:hover {
    transform: none; /* overridden by JS perspective tilt */
    border-color: rgba(6,214,196,0.2);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35), 0 0 40px rgba(6,214,196,0.07);
  }
  .testimonial-stars {
    transition: letter-spacing 0.3s ease, color 0.3s ease, text-shadow 0.3s ease;
    font-size: 1rem;
    color: #f59e0b;
    margin-top: 4px;
    display: block;
  }
  .testimonial-card:hover .testimonial-stars {
    letter-spacing: 3px;
    text-shadow: 0 0 14px rgba(245,158,11,0.6);
  }

  /* ===== SECTION EYEBROW PULSE ON HOVER ===== */
  .section-eyebrow {
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }
  .section-eyebrow:hover {
    box-shadow: 0 0 20px rgba(6,214,196,0.35);
    background: rgba(6,214,196,0.2);
  }

  /* ===== PRIMARY BUTTON — outer glow ring ===== */
  .btn-primary::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(6,214,196,0.6), rgba(168,85,247,0.4));
    opacity: 0;
    z-index: -1;
    transition: opacity 0.35s ease;
    filter: blur(10px);
  }
  .btn-primary:hover::before {
    opacity: 1;
  }

  /* ===== CUSTOM CURSOR ===== */
  #cursor-globe {
    position: fixed;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid rgba(6, 214, 196, 0.5);
    background: transparent;
    pointer-events: none;
    z-index: 99999;
    transform: translate(-50%, -50%);
    transition: background 0.3s ease, border-color 0.3s ease;
    mix-blend-mode: screen;
  }
  #cursor-dot {
    position: fixed;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #06d6c4;
    pointer-events: none;
    z-index: 100000;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 10px rgba(6, 214, 196, 0.9);
  }
  @media (hover: none) {
    #cursor-globe, #cursor-dot { display: none; }
  }

  /* ===== SCROLL PROGRESS BAR ===== */
  #scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, #06d6c4, #a855f7, #06d6c4);
    background-size: 200% auto;
    animation: gradientShift 3s linear infinite;
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 99998;
    pointer-events: none;
  }

  /* ===== 3D FLOATING SHAPES ===== */
  .hero-3d-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .shape-wrapper {
    position: absolute;
    will-change: transform;
  }

  /* --- CSS 3D Cube --- */
  .cube3d {
    width: 80px;
    height: 80px;
    transform-style: preserve-3d;
    animation: rotateCube 15s linear infinite;
    position: relative;
  }

  .cube3d-sm {
    width: 50px;
    height: 50px;
    animation-duration: 11s;
    animation-direction: reverse;
  }

  .cube3d-xs {
    width: 35px;
    height: 35px;
    animation-duration: 9s;
  }

  .cube3d-face {
    position: absolute;
    width: 80px;
    height: 80px;
    border: 1px solid rgba(6, 214, 196, 0.38);
    background: rgba(6, 214, 196, 0.025);
    backdrop-filter: blur(4px);
  }
  .cube3d-sm .cube3d-face { width: 50px; height: 50px; border-color: rgba(168, 85, 247, 0.38); background: rgba(168, 85, 247, 0.025); }
  .cube3d-xs .cube3d-face { width: 35px; height: 35px; border-color: rgba(99, 179, 255, 0.38); background: rgba(99, 179, 255, 0.025); }

  .cube3d .front  { transform: translateZ(40px); }
  .cube3d .back   { transform: translateZ(-40px) rotateY(180deg); }
  .cube3d .left   { transform: translateX(-40px) rotateY(-90deg); }
  .cube3d .right  { transform: translateX(40px) rotateY(90deg); }
  .cube3d .top    { transform: translateY(-40px) rotateX(90deg); }
  .cube3d .bottom { transform: translateY(40px) rotateX(-90deg); }

  .cube3d-sm .front  { transform: translateZ(25px); }
  .cube3d-sm .back   { transform: translateZ(-25px) rotateY(180deg); }
  .cube3d-sm .left   { transform: translateX(-25px) rotateY(-90deg); }
  .cube3d-sm .right  { transform: translateX(25px) rotateY(90deg); }
  .cube3d-sm .top    { transform: translateY(-25px) rotateX(90deg); }
  .cube3d-sm .bottom { transform: translateY(25px) rotateX(-90deg); }

  .cube3d-xs .front  { transform: translateZ(17.5px); }
  .cube3d-xs .back   { transform: translateZ(-17.5px) rotateY(180deg); }
  .cube3d-xs .left   { transform: translateX(-17.5px) rotateY(-90deg); }
  .cube3d-xs .right  { transform: translateX(17.5px) rotateY(90deg); }
  .cube3d-xs .top    { transform: translateY(-17.5px) rotateX(90deg); }
  .cube3d-xs .bottom { transform: translateY(17.5px) rotateX(-90deg); }

  @keyframes rotateCube {
    0%   { transform: rotateX(0deg)   rotateY(0deg)   rotateZ(0deg); }
    33%  { transform: rotateX(120deg) rotateY(90deg)  rotateZ(45deg); }
    66%  { transform: rotateX(240deg) rotateY(200deg) rotateZ(120deg); }
    100% { transform: rotateX(360deg) rotateY(360deg) rotateZ(360deg); }
  }

  /* --- CSS 3D Rings --- */
  .ring3d {
    width: 110px;
    height: 110px;
    border: 2px solid rgba(168, 85, 247, 0.45);
    border-radius: 50%;
    animation: rotateRing 9s linear infinite;
    position: relative;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.2), inset 0 0 20px rgba(168, 85, 247, 0.05);
  }

  .ring3d::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(6, 214, 196, 0.3);
    border-radius: 50%;
    animation: rotateRingInner 5s linear infinite reverse;
  }

  .ring3d::after {
    content: '';
    position: absolute;
    inset: 28px;
    border: 1px dashed rgba(168, 85, 247, 0.2);
    border-radius: 50%;
    animation: rotateRingInner 8s linear infinite;
  }

  .ring3d-sm {
    width: 65px;
    height: 65px;
    border-color: rgba(6, 214, 196, 0.4);
    animation-duration: 6s;
    animation-direction: reverse;
    box-shadow: 0 0 14px rgba(6, 214, 196, 0.2);
  }
  .ring3d-sm::before { inset: 8px; border-color: rgba(168, 85, 247, 0.25); }
  .ring3d-sm::after { display: none; }

  .ring3d-lg {
    width: 160px;
    height: 160px;
    border-color: rgba(6, 214, 196, 0.25);
    animation-duration: 14s;
    box-shadow: 0 0 30px rgba(6, 214, 196, 0.12);
  }
  .ring3d-lg::before { inset: 20px; border-color: rgba(168, 85, 247, 0.18); }

  @keyframes rotateRing {
    0%   { transform: perspective(400px) rotateX(65deg) rotateZ(0deg); }
    100% { transform: perspective(400px) rotateX(65deg) rotateZ(360deg); }
  }

  @keyframes rotateRingInner {
    0%   { transform: rotateZ(0deg); }
    100% { transform: rotateZ(360deg); }
  }

  /* --- CSS 3D Diamond --- */
  .diamond3d {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, rgba(6, 214, 196, 0.08), rgba(6, 214, 196, 0.02));
    border: 1px solid rgba(6, 214, 196, 0.45);
    animation: rotateDiamond 7s ease-in-out infinite;
    box-shadow: 0 0 24px rgba(6, 214, 196, 0.22), inset 0 0 12px rgba(6, 214, 196, 0.06);
  }

  .diamond3d-purple {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.08), rgba(168, 85, 247, 0.02));
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: 0 0 24px rgba(168, 85, 247, 0.22), inset 0 0 12px rgba(168, 85, 247, 0.06);
    animation-delay: -3s;
    animation-direction: reverse;
  }

  @keyframes rotateDiamond {
    0%   { transform: perspective(250px) rotateX(45deg) rotateZ(45deg) translateY(0px); }
    25%  { transform: perspective(250px) rotateX(70deg) rotateZ(100deg) translateY(-12px); }
    50%  { transform: perspective(250px) rotateX(30deg) rotateZ(135deg) translateY(-6px); }
    75%  { transform: perspective(250px) rotateX(60deg) rotateZ(200deg) translateY(-14px); }
    100% { transform: perspective(250px) rotateX(45deg) rotateZ(225deg) translateY(0px); }
  }

  /* --- Icosahedron (CSS approximation) --- */
  .icosa3d {
    width: 58px;
    height: 58px;
    border: 1px solid rgba(99, 179, 255, 0.38);
    border-radius: 22% 78% 35% 65% / 68% 28% 72% 32%;
    background: rgba(99, 179, 255, 0.03);
    animation: rotateIcosa 10s linear infinite;
    box-shadow: 0 0 20px rgba(99, 179, 255, 0.18);
  }

  @keyframes rotateIcosa {
    0%   { transform: rotate(0deg) scale(1);   border-radius: 22% 78% 35% 65% / 68% 28% 72% 32%; }
    25%  { transform: rotate(90deg) scale(1.1); border-radius: 55% 45% 70% 30% / 30% 70% 30% 70%; }
    50%  { transform: rotate(180deg) scale(1);  border-radius: 78% 22% 65% 35% / 32% 72% 28% 68%; }
    75%  { transform: rotate(270deg) scale(1.1);border-radius: 45% 55% 30% 70% / 70% 30% 70% 30%; }
    100% { transform: rotate(360deg) scale(1);  border-radius: 22% 78% 35% 65% / 68% 28% 72% 32%; }
  }

  /* --- SVG Shapes --- */
  .shape-svg-pyramid {
    width: 90px;
    height: 90px;
    overflow: visible;
    filter: drop-shadow(0 0 8px rgba(6, 214, 196, 0.25));
  }

  .shape-svg-hex {
    width: 80px;
    height: 80px;
    overflow: visible;
    filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.25));
  }

  /* --- Shape Positions --- */
  .shape-cube-1   { top: 8%;  right: 7%;  opacity: 0.65; transform-style: preserve-3d; perspective: 400px; }
  .shape-cube-2   { bottom: 22%; left: 4%; opacity: 0.55; transform-style: preserve-3d; perspective: 400px; }
  .shape-cube-3   { top: 45%; left: 2%;  opacity: 0.45; transform-style: preserve-3d; perspective: 400px; }
  .shape-ring-1   { top: 18%; left: 9%;  opacity: 0.5; }
  .shape-ring-2   { bottom: 12%; right: 12%; opacity: 0.55; }
  .shape-ring-3   { top: 60%; right: 3%; opacity: 0.35; }
  .shape-diamond-1 { top: 35%; right: 18%; opacity: 0.55; }
  .shape-diamond-2 { bottom: 30%; left: 15%; opacity: 0.48; }
  .shape-icosa-1  { top: 70%; left: 22%; opacity: 0.4; }
  .shape-pyramid-1 { top: 14%; right: 30%; opacity: 0.45; }
  .shape-hex-1    { bottom: 18%; left: 28%; opacity: 0.4; }

  @media (max-width: 768px) {
    .shape-cube-1, .shape-ring-3, .shape-pyramid-1, .shape-hex-1 { display: none; }
    .hero-3d-shapes { opacity: 0.6; }
  }

  /* ===== DECOR SPHERE SVG ===== */
  .decor-sphere-svg {
    display: block;
  }

  /* ===== SECTION ENTRY HIGHLIGHT LINE ===== */
  .section-entered::after {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(6,214,196,0.3), rgba(168,85,247,0.2), transparent);
    animation: fadeInLine 0.8s ease forwards;
  }

  @keyframes fadeInLine {
    from { opacity: 0; transform: scaleX(0); }
    to   { opacity: 1; transform: scaleX(1); }
  }

  /* ===== ENHANCED REVEAL WITH 3D ===== */
  .hero-title {
    transform-style: preserve-3d;
    perspective: 600px;
  }

  /* ===== FLOATING BODY PARTICLE ===== */
  @keyframes bodyParticleFloat {
    0%   { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
  }

  /* ===== CAP CARD FEATURED GLOW PULSE ===== */
  .cap-card-featured {
    animation: featuredPulse 3s ease-in-out infinite;
  }

  @keyframes featuredPulse {
    0%, 100% { box-shadow: 0 0 0 1px rgba(168, 85, 247, 0.2), 0 8px 32px rgba(0,0,0,0.4); }
    50%       { box-shadow: 0 0 0 2px rgba(168, 85, 247, 0.45), 0 8px 48px rgba(168,85,247,0.25); }
  }

  /* ===== HERO BADGE FLOAT ===== */
  .hero-badge .badge {
    animation: badgeFloat 4s ease-in-out infinite;
  }

  @keyframes badgeFloat {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-5px); }
  }

  /* ===== SECTION FLOAT DECOR ===== */
  .section-float-decor {
    overflow: visible;
  }

  /* ===== HERO-3D-SHAPES - REMOVE POINTER NONE SO JS CAN OVERRIDE PER-SHAPE ===== */
  .hero-3d-shapes {
    pointer-events: none !important; /* container stays none; JS sets auto on individual wrappers */
  }

  /* ===== NEW SHAPE POSITIONS ===== */
  .shape-torus-1  { bottom: 28%; right: 5%;  opacity: 0.6; }
  .shape-dna-1    { top: 10%;  left: 20%; opacity: 0.55; }
  .shape-wave-1   { bottom: 10%; right: 25%; opacity: 0.45; }
  .shape-octa-1   { top: 42%;  right: 28%; opacity: 0.5; }

  /* Extra shape SVG sizes */
  .shape-svg-torus { width: 130px; height: 70px;  filter: drop-shadow(0 0 6px rgba(6,214,196,0.2)); overflow: visible; }
  .shape-svg-dna   { width: 44px;  height: 130px; filter: drop-shadow(0 0 6px rgba(168,85,247,0.22)); overflow: visible; }
  .shape-svg-wave  { width: 140px; height: 55px;  filter: drop-shadow(0 0 5px rgba(6,214,196,0.18)); overflow: visible; }
  .shape-svg-octa  { width: 90px;  height: 90px;  filter: drop-shadow(0 0 6px rgba(245,158,11,0.22)); overflow: visible; }

  @media (max-width: 900px) {
    .shape-torus-1, .shape-dna-1, .shape-wave-1, .shape-octa-1 { display: none; }
  }

  /* ===== HOLOGRAM SPHERE ===== */
  .hero-hologram-wrap {
    position: absolute;
    right: 3%;
    top: 50%;
    transform: translateY(-50%);
    width: 300px;
    height: 300px;
    pointer-events: none;
    z-index: 1;
    perspective: 700px;
    display: none; /* shown via media query */
  }

  @media (min-width: 1100px) {
    .hero-hologram-wrap { display: block; }
  }

  .hero-hologram {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
  }

  .holo-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid rgba(6, 214, 196, 0.35);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .holo-r1 { width: 72px;  height: 72px;  border-color: rgba(168,85,247,0.55); transform: translate(-50%,-50%) perspective(400px) rotateX(70deg); }
  .holo-r2 { width: 110px; height: 110px; border-color: rgba(6,214,196,0.4);   transform: translate(-50%,-50%) perspective(400px) rotateX(60deg) rotateZ(30deg); }
  .holo-r3 { width: 160px; height: 160px; border-color: rgba(6,214,196,0.28);  transform: translate(-50%,-50%) perspective(400px) rotateX(72deg) rotateZ(60deg); }
  .holo-r4 { width: 220px; height: 220px; border-color: rgba(168,85,247,0.2);  transform: translate(-50%,-50%) perspective(400px) rotateX(65deg) rotateZ(15deg); }

  .holo-equator {
    position: absolute;
    width: 240px; height: 42px;
    border: 1px solid rgba(6,214,196,0.3);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .holo-meridian {
    position: absolute;
    width: 42px; height: 240px;
    border: 1px solid rgba(6,214,196,0.22);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .holo-core {
    position: absolute;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6,214,196,1) 0%, rgba(6,214,196,0.4) 50%, transparent 100%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 24px rgba(6, 214, 196, 0.7), 0 0 60px rgba(6, 214, 196, 0.3);
  }

  .holo-glow {
    position: absolute;
    width: 260px; height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6,214,196,0.07) 0%, rgba(168,85,247,0.04) 50%, transparent 75%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.5;
  }

  .holo-grid {
    position: absolute;
    width: 200px; height: 200px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.6;
  }

  /* ===== AMBIENT CURSOR BLOB ===== */
  #cursor-blob {
    position: fixed;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6,214,196,0.06) 0%, rgba(168,85,247,0.04) 50%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    filter: blur(40px);
    mix-blend-mode: screen;
    top: 0; left: 0;
  }

  /* ===== GLITCH EFFECT ===== */
  .hero-title.glitch-active {
    animation: glitchAnim 0.06s steps(1) infinite;
  }

  @keyframes glitchAnim {
    0%   { clip-path: inset(0 0 90% 0); transform: translate(-3px, 1px); filter: hue-rotate(90deg); }
    20%  { clip-path: inset(20% 0 60% 0); transform: translate(3px, -2px); }
    40%  { clip-path: inset(50% 0 30% 0); transform: translate(-2px, 2px); filter: hue-rotate(-45deg); }
    60%  { clip-path: inset(70% 0 10% 0); transform: translate(2px, 0px); }
    80%  { clip-path: inset(10% 0 80% 0); transform: translate(-1px, -1px); }
    100% { clip-path: none; transform: none; filter: none; }
  }

  /* ===== CARD SPOTLIGHT OVERLAY ===== */
  .card-lit::before {
    content: '' !important;
    position: absolute !important;
    inset: 0 !important;
    background: radial-gradient(circle 140px at var(--mx, 50%) var(--my, 50%), rgba(6,214,196,0.08) 0%, transparent 70%) !important;
    pointer-events: none !important;
    z-index: 1 !important;
    border-radius: inherit !important;
  }

  /* ===== SHAPE-WRAPPER HOVER FEEDBACK ===== */
  .shape-wrapper[data-interactive] {
    transition: filter 0.3s ease;
    transform-style: preserve-3d;
    cursor: grab;
  }
  .shape-wrapper[data-interactive].is-dragging {
    cursor: grabbing;
    z-index: 100;
  }

  /* ===== REVEAL SUBTITLE PLACEHOLDER (prevents layout shift) ===== */
  .section-subtitle {
    will-change: filter, opacity, transform;
  }

  /* ===== PLATFORM TRIO SECTION ===== */
  .bento-platform-trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
  }

  @media (max-width: 900px) { .bento-platform-trio { grid-template-columns: 1fr; } }

  .bento-platform {
    position: relative;
    overflow: hidden;
    min-height: 280px;
  }

  .bento-platform-orb {
    position: absolute;
    width: 160px; height: 160px;

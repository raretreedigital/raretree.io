<script>
  // ===== HERO CANVAS ANIMATION =====
  (function () {
    const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    let W = 0, H = 0, mouse = { x: -9999, y: -9999 };

    // Cursor trail points
    interface TrailPoint { x: number; y: number; alpha: number; r: number; }
    const trail: TrailPoint[] = [];
    const TRAIL_MAX = 28;

    // Click ripples
    interface Ripple { x: number; y: number; r: number; maxR: number; alpha: number; }
    const ripples: Ripple[] = [];

    function resize() {
      W = canvas!.offsetWidth;
      H = canvas!.offsetHeight;
      canvas!.width = W;
      canvas!.height = H;
    }
    resize();
    window.addEventListener('resize', () => { resize(); });
    window.addEventListener('mousemove', e => {
      const r = canvas!.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
      // Emit trail point
      if (mouse.x > 0 && mouse.y > 0 && mouse.x < W && mouse.y < H) {
        trail.push({ x: mouse.x, y: mouse.y, alpha: 0.55, r: Math.random() * 1.6 + 0.8 });
        if (trail.length > TRAIL_MAX) trail.shift();
      }
    });
    window.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

    // Click ripple
    canvas!.addEventListener('click', (e: MouseEvent) => {
      const r = canvas!.getBoundingClientRect();
      const rx = e.clientX - r.left;
      const ry = e.clientY - r.top;
      ripples.push({ x: rx, y: ry, r: 0, maxR: 90, alpha: 0.6 });
    });

    // Color palette
    const C_TEAL   = '6,214,196';
    const C_PURPLE = '168,85,247';
    const C_BLUE   = '99,179,255';

    // --- Orbit nodes (geometric, no text labels) ---
    interface OrbNode { ring: number; angle: number; baseSize: number; color: string; phase: number; shape: 'circle' | 'diamond'; }
    const ORBIT_NODES: OrbNode[] = [
      { ring: 0, angle: 0,                      baseSize: 4.5, color: C_TEAL,       phase: 0.0, shape: 'diamond' },
      { ring: 0, angle: Math.PI * 0.5,          baseSize: 3.5, color: C_BLUE,       phase: 1.5, shape: 'circle'  },
      { ring: 0, angle: Math.PI,                baseSize: 4.5, color: C_TEAL,       phase: 2.8, shape: 'diamond' },
      { ring: 0, angle: Math.PI * 1.5,          baseSize: 3.5, color: C_PURPLE,     phase: 0.9, shape: 'circle'  },
      { ring: 1, angle: 0.4,                    baseSize: 5.5, color: C_PURPLE,     phase: 0.4, shape: 'diamond' },
      { ring: 1, angle: 0.4 + Math.PI * 0.67,  baseSize: 4.0, color: C_TEAL,       phase: 2.1, shape: 'circle'  },
      { ring: 1, angle: 0.4 + Math.PI * 1.33,  baseSize: 4.0, color: C_BLUE,       phase: 3.4, shape: 'circle'  },
      { ring: 1, angle: 2.2,                    baseSize: 4.5, color: '255,150,55', phase: 0.2, shape: 'diamond' },
      { ring: 2, angle: 0.8,                    baseSize: 6.0, color: C_PURPLE,     phase: 1.1, shape: 'diamond' },
      { ring: 2, angle: 0.8 + Math.PI * 0.67,  baseSize: 4.5, color: C_TEAL,       phase: 2.5, shape: 'circle'  },
      { ring: 2, angle: 0.8 + Math.PI * 1.33,  baseSize: 5.0, color: C_BLUE,       phase: 0.7, shape: 'circle'  },
      { ring: 2, angle: 5.1,                    baseSize: 4.5, color: '255,90,90',  phase: 1.7, shape: 'diamond' },
    ];

    const RING_RADII = [0.22, 0.34, 0.44]; // fraction of min(W,H)/2
    const RING_SPEEDS = [0.00028, -0.00019, 0.00013];
    const RING_TILTS  = [0, 0.28, -0.18]; // perspective tilt (y-scale)

    // --- Shooting star meteors ---
    interface Meteor { x: number; y: number; vx: number; vy: number; life: number; maxLife: number; color: string; }
    const meteors: Meteor[] = [];

    // --- Ambient particles ---
    interface Particle { x: number; y: number; vx: number; vy: number; r: number; color: string; alpha: number; }
    const particles: Particle[] = [];
    const NUM_P = 55;
    const LINK_DIST = 130;

    function spawnParticle(): Particle {
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 1.8 + 0.6,
        color: Math.random() > 0.55 ? C_TEAL : (Math.random() > 0.5 ? C_PURPLE : C_BLUE),
        alpha: Math.random() * 0.5 + 0.2,
      };
    }

    for (let i = 0; i < NUM_P; i++) particles.push(spawnParticle());

    // --- Pulse rings ---
    interface Pulse { r: number; maxR: number; alpha: number; }
    const pulses: Pulse[] = [];
    let pulseTimer = 0;
    let meteorTimer = 0;

    let frame = 0;
    function draw(ts: number) {
      ctx.clearRect(0, 0, W, H);
      frame = ts;

      // --- Draw cursor trail ---
      for (let i = trail.length - 1; i >= 0; i--) {
        const t = trail[i];
        t.alpha -= 0.035;
        if (t.alpha <= 0) { trail.splice(i, 1); continue; }
        const fade = i / trail.length;
        ctx.beginPath();
        ctx.arc(t.x, t.y, t.r * fade, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${C_TEAL},${(t.alpha * fade).toFixed(3)})`;
        ctx.fill();
      }

      // --- Draw click ripples ---
      for (let i = ripples.length - 1; i >= 0; i--) {
        const rp = ripples[i];
        rp.r += 2.4;
        rp.alpha -= 0.018;
        if (rp.alpha <= 0 || rp.r > rp.maxR) { ripples.splice(i, 1); continue; }
        const lineA = rp.alpha * (1 - rp.r / rp.maxR);
        ctx.beginPath();
        ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${C_TEAL},${lineA.toFixed(3)})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        // inner ring (tighter)
        if (rp.r > 20) {
          ctx.beginPath();
          ctx.arc(rp.x, rp.y, rp.r * 0.55, 0, Math.PI * 2);
          ctx.strokeStyle = `rgba(${C_PURPLE},${(lineA * 0.5).toFixed(3)})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }

      const cx = W / 2;
      const cy = H * 0.46;
      const base = Math.min(W, H) * 0.5;

      // --- Spawn pulse every ~2.8s ---
      pulseTimer += 16;
      if (pulseTimer > 2800) {
        pulseTimer = 0;
        pulses.push({ r: 0, maxR: base * 0.52, alpha: 0.35 });
      }

      // --- Meteor shooting stars ---
      meteorTimer += 16;
      if (meteorTimer > 4200 + Math.random() * 2800) {
        meteorTimer = 0;
        const side = Math.floor(Math.random() * 4);
        let mx = 0, my = 0;
        if (side === 0) { mx = Math.random() * W; my = -5; }
        else if (side === 1) { mx = W + 5; my = Math.random() * H * 0.7; }
        else if (side === 2) { mx = Math.random() * W; my = H + 5; }
        else { mx = -5; my = Math.random() * H; }
        const ang = Math.atan2(cy - my, cx - mx) + (Math.random() - 0.5) * 0.65;
        const spd = 5 + Math.random() * 3;
        meteors.push({ x: mx, y: my, vx: Math.cos(ang) * spd, vy: Math.sin(ang) * spd,
          life: 0, maxLife: 45 + Math.random() * 45, color: Math.random() > 0.5 ? C_TEAL : C_BLUE });
      }
      for (let i = meteors.length - 1; i >= 0; i--) {
        const m = meteors[i];
        m.x += m.vx; m.y += m.vy; m.life++;
        if (m.life > m.maxLife || m.x < -60 || m.x > W + 60 || m.y < -60 || m.y > H + 60) {
          meteors.splice(i, 1); continue;
        }
        const ma = Math.sin(Math.PI * m.life / m.maxLife) * 0.9;
        const tg = ctx.createLinearGradient(m.x - m.vx * 10, m.y - m.vy * 10, m.x, m.y);
        tg.addColorStop(0, `rgba(${m.color},0)`);
        tg.addColorStop(1, `rgba(${m.color},${ma.toFixed(3)})`);
        ctx.strokeStyle = tg;
        ctx.lineWidth = 1.8;
        ctx.beginPath();
        ctx.moveTo(m.x - m.vx * 10, m.y - m.vy * 10);
        ctx.lineTo(m.x, m.y);
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(m.x, m.y, 2.2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${m.color},${ma.toFixed(3)})`;
        ctx.fill();
      }

      // --- Draw pulses ---
      pulses.forEach((p, i) => {
        p.r += 1.2;
        p.alpha -= 0.0028;
        if (p.alpha <= 0) { pulses.splice(i, 1); return; }
        ctx.beginPath();
        ctx.arc(cx, cy, p.r, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${C_TEAL},${p.alpha.toFixed(3)})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      });

      // --- Draw orbit ring traces ---
      RING_RADII.forEach((rf, ri) => {
        const rr = base * rf;
        const tilt = RING_TILTS[ri];
        ctx.beginPath();
        ctx.save();
        ctx.translate(cx, cy);
        ctx.scale(1, 0.42 + tilt);
        ctx.arc(0, 0, rr, 0, Math.PI * 2);
        ctx.restore();
        ctx.strokeStyle = ri === 1
          ? `rgba(${C_PURPLE},0.1)`
          : `rgba(${C_TEAL},0.08)`;
        ctx.lineWidth = 0.8;
        ctx.stroke();
      });

      // --- Draw & update ambient particles ---
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        // Mouse repulsion
        const dx = p.x - mouse.x, dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) {
          p.vx += (dx / dist) * 0.06;
          p.vy += (dy / dist) * 0.06;
        }
        p.x += p.vx; p.y += p.vy;
        // Clamp speed
        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (spd > 0.8) { p.vx *= 0.97; p.vy *= 0.97; }
        // Wrap
        if (p.x < -10) p.x = W + 10;
        if (p.x > W + 10) p.x = -10;
        if (p.y < -10) p.y = H + 10;
        if (p.y > H + 10) p.y = -10;
        // Draw dot
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${p.color},${p.alpha})`;
        ctx.fill();
      }

      // --- Draw connections between nearby particles ---
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < LINK_DIST) {
            const a = (1 - d / LINK_DIST) * 0.18;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(${C_TEAL},${a.toFixed(3)})`;
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }

      // --- Draw orbiting geometric nodes ---
      const orbPos: Array<{ x: number; y: number; color: string }> = [];
      ORBIT_NODES.forEach(t => {
        const ri = t.ring;
        t.angle += RING_SPEEDS[ri] * 16;
        const rr = base * RING_RADII[ri];
        const tilt = 0.42 + RING_TILTS[ri];
        let nx = cx + Math.cos(t.angle) * rr;
        let ny = cy + Math.sin(t.angle) * rr * tilt;

        // Magnetic pull toward mouse
        const mdx = mouse.x - nx, mdy = mouse.y - ny;
        const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
        if (mDist < 120 && mDist > 0) {
          const pull = (1 - mDist / 120) * 18;
          nx += (mdx / mDist) * pull;
          ny += (mdy / mDist) * pull;
        }
        orbPos.push({ x: nx, y: ny, color: t.color });

        // Pulsing size
        const pSize = t.baseSize * (1 + 0.28 * Math.sin(ts * 0.0018 + t.phase));

        // Glow halo
        const g = ctx.createRadialGradient(nx, ny, 0, nx, ny, pSize * 5);
        g.addColorStop(0, `rgba(${t.color},0.32)`);
        g.addColorStop(1, `rgba(${t.color},0)`);
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(nx, ny, pSize * 5, 0, Math.PI * 2);
        ctx.fill();

        // Node shape — diamond or circle
        ctx.save();
        ctx.translate(nx, ny);
        if (t.shape === 'diamond') {
          ctx.rotate(Math.PI / 4 + ts * 0.0005 * (ri + 1));
          const hs = pSize * 0.82;
          ctx.beginPath();
          ctx.moveTo(0, -hs); ctx.lineTo(hs, 0); ctx.lineTo(0, hs); ctx.lineTo(-hs, 0);
          ctx.closePath();
        } else {
          ctx.beginPath();
          ctx.arc(0, 0, pSize, 0, Math.PI * 2);
        }
        ctx.fillStyle = `rgba(${t.color},0.92)`;
        ctx.fill();
        ctx.strokeStyle = `rgba(${t.color},0.5)`;
        ctx.lineWidth = 0.9;
        ctx.stroke();
        ctx.restore();

        // Faint line to center
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(nx, ny);
        ctx.strokeStyle = `rgba(${t.color},0.045)`;
        ctx.lineWidth = 0.7;
        ctx.stroke();
      });

      // --- Arc sparks between nearby nodes ---
      for (let i = 0; i < orbPos.length; i++) {
        for (let j = i + 1; j < orbPos.length; j++) {
          const adx = orbPos[i].x - orbPos[j].x;
          const ady = orbPos[i].y - orbPos[j].y;
          const ad = Math.sqrt(adx * adx + ady * ady);
          if (ad < 70) {
            const arcA = (1 - ad / 70) * 0.5;
            const amx = (orbPos[i].x + orbPos[j].x) / 2 + (orbPos[j].y - orbPos[i].y) * 0.22;
            const amy = (orbPos[i].y + orbPos[j].y) / 2 - (orbPos[j].x - orbPos[i].x) * 0.22;
            ctx.beginPath();
            ctx.moveTo(orbPos[i].x, orbPos[i].y);
            ctx.quadraticCurveTo(amx, amy, orbPos[j].x, orbPos[j].y);
            ctx.strokeStyle = `rgba(${C_TEAL},${arcA.toFixed(3)})`;
            ctx.lineWidth = 0.9;
            ctx.stroke();
          }
        }
      }

      // --- Rotating hexagonal core ---
      const hexTime = ts * 0.0007;
      const cg = ctx.createRadialGradient(cx, cy, 0, cx, cy, 32);
      cg.addColorStop(0, `rgba(${C_TEAL},0.6)`);
      cg.addColorStop(0.5, `rgba(${C_TEAL},0.16)`);
      cg.addColorStop(1, `rgba(${C_TEAL},0)`);
      ctx.fillStyle = cg;
      ctx.beginPath();
      ctx.arc(cx, cy, 32, 0, Math.PI * 2);
      ctx.fill();
      // Outer hexagon
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(hexTime);
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (i / 6) * Math.PI * 2;
        i === 0 ? ctx.moveTo(Math.cos(a) * 16, Math.sin(a) * 16)
                : ctx.lineTo(Math.cos(a) * 16, Math.sin(a) * 16);
      }
      ctx.closePath();
      ctx.strokeStyle = `rgba(${C_TEAL},0.75)`;
      ctx.lineWidth = 1.2;
      ctx.stroke();
      // Inner triangle counter-rotating
      ctx.rotate(-hexTime * 2.6);
      ctx.beginPath();
      for (let i = 0; i < 3; i++) {
        const a = (i / 3) * Math.PI * 2;
        i === 0 ? ctx.moveTo(Math.cos(a) * 8, Math.sin(a) * 8)
                : ctx.lineTo(Math.cos(a) * 8, Math.sin(a) * 8);
      }
      ctx.closePath();
      ctx.strokeStyle = `rgba(${C_PURPLE},0.65)`;
      ctx.lineWidth = 1;
      ctx.stroke();
      ctx.restore();
      // Center dot
      ctx.beginPath();
      ctx.arc(cx, cy, 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${C_TEAL},1)`;
      ctx.fill();

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  })();

  // Counter animation
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0');
    const duration = 1800;
    const step = target / (duration / 16);
    let current = 0;

    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      el.textContent = Math.floor(current).toString();
    }, 16);
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        animateCounter(el);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.counter, [data-target]').forEach(el => {
    counterObserver.observe(el as HTMLElement);
  });

  // ===== Capability Cards 3D Tilt + Testimonial Tilt =====
  document.querySelectorAll<HTMLElement>('[data-tilt], .testimonial-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - 0.5;
      const y = (e.clientY - r.top) / r.height - 0.5;
      card.style.transform = `perspective(900px) rotateX(${(-y * 10).toFixed(2)}deg) rotateY(${(x * 10).toFixed(2)}deg) translateZ(8px)`;
      const glow = card.querySelector<HTMLElement>('.cap-card-glow');
      if (glow) {
        const cg = getComputedStyle(card).getPropertyValue('--cg').trim() || '#06d6c4';
        glow.style.background = `radial-gradient(ellipse at ${((x + 0.5) * 100).toFixed(1)}% ${((y + 0.5) * 100).toFixed(1)}%, color-mix(in srgb, ${cg} 22%, transparent) 0%, transparent 60%)`;
        glow.style.opacity = '1';
      }
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
      const glow = card.querySelector<HTMLElement>('.cap-card-glow');
      if (glow) glow.style.opacity = '0';
    });
  });

  // ===== Bento Card Spotlight (cursor-tracking inner glow) =====
  document.querySelectorAll<HTMLElement>('.bento-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${((e.clientX - r.left) / r.width * 100).toFixed(1)}%`);
      card.style.setProperty('--my', `${((e.clientY - r.top) / r.height * 100).toFixed(1)}%`);
    });
  });
</script>

<!-- ===== GSAP SCROLL & 3D ANIMATIONS ===== -->
<script is:inline>
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  // ─── STEP 1: Strip CSS reveal classes from elements GSAP will control
  // so the CSS IntersectionObserver + inline-style GSAP don't fight each other.
  const gsapControlled = [
    '.hero-badge', '.hero-title', '.hero-subtitle',
    '.hero-actions .btn', '.hero-stats',
    '.bento-card', '.cap-card', '.stat-card',
    '.testimonial-card', '.process-step', '.cta-inner',
  ];
  gsapControlled.forEach(sel => {
    document.querySelectorAll(sel).forEach(el => {
      el.classList.remove('reveal', 'reveal-left', 'reveal-right', 'reveal-scale');
      el.classList.remove('delay-1', 'delay-2', 'delay-3', 'delay-4', 'delay-5');
      // Ensure fully visible by default; GSAP will set initial state via gsap.set()
      el.style.opacity = '1';
      el.style.transform = '';
    });
  });

  // ─── STEP 2: Set the initial hidden states explicitly via GSAP
  gsap.set('.hero-badge', { autoAlpha: 0, scale: 0.5 });
  gsap.set('.hero-title', { autoAlpha: 0, y: 60 });
  gsap.set('.hero-subtitle', { autoAlpha: 0, y: 30 });
  gsap.set('.hero-actions .btn', { autoAlpha: 0, y: 20 });
  gsap.set('.hero-stats', { autoAlpha: 0, y: 20, scale: 0.96 });

  gsap.set('.bento-card', { autoAlpha: 0, y: 55, rotationX: 15, transformOrigin: 'top center' });
  gsap.set('.cap-card', { autoAlpha: 0, y: 60, scale: 0.9, rotationY: 12 });
  gsap.set('.stat-card', { autoAlpha: 0, y: 50, scale: 0.85 });
  gsap.set('.process-step', { autoAlpha: 0, y: 40 });
  gsap.set('.cta-inner', { autoAlpha: 0, scale: 0.88, y: 40 });

  // Testimonials: set per-card based on index
  document.querySelectorAll('.testimonial-card').forEach((card, i) => {
    const xDir = i === 0 ? -80 : i === 2 ? 80 : 0;
    gsap.set(card, { autoAlpha: 0, x: xDir, y: xDir === 0 ? 50 : 20, rotation: xDir === 0 ? 0 : (i === 0 ? -3 : 3) });
  });

  /* ─── CUSTOM CURSOR GLOBE ─── */
  const cursorGlobe = document.createElement('div');
  cursorGlobe.id = 'cursor-globe';
  document.body.appendChild(cursorGlobe);
  const cursorDot = document.createElement('div');
  cursorDot.id = 'cursor-dot';
  document.body.appendChild(cursorDot);

  let cursorX = -200, cursorY = -200;
  let globeX = -200, globeY = -200;

  document.addEventListener('mousemove', (e) => {
    cursorX = e.clientX;
    cursorY = e.clientY;
    gsap.to(cursorDot, { x: cursorX, y: cursorY, duration: 0.08, ease: 'none' });
  });

  gsap.ticker.add(() => {
    globeX += (cursorX - globeX) * 0.12;
    globeY += (cursorY - globeY) * 0.12;
    gsap.set(cursorGlobe, { x: globeX, y: globeY });
  });

  document.querySelectorAll('a, button, .btn, .cap-card, .bento-card, .stat-card, .testimonial-card').forEach(el => {
    el.addEventListener('mouseenter', () => gsap.to(cursorGlobe, { scale: 2.5, opacity: 0.75, duration: 0.3, backgroundColor: 'rgba(6,214,196,0.15)', borderColor: 'rgba(6,214,196,0.8)' }));
    el.addEventListener('mouseleave', () => gsap.to(cursorGlobe, { scale: 1, opacity: 1, duration: 0.3, backgroundColor: 'transparent', borderColor: 'rgba(6,214,196,0.5)' }));
  });

  /* ─── MAGNETIC BUTTONS ─── */
  document.querySelectorAll('.btn-primary, .btn-secondary').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(btn, { x: x * 0.28, y: y * 0.28, duration: 0.35, ease: 'power2.out' });
    });
    btn.addEventListener('mouseleave', () => {
      gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.5)' });
    });
  });

  /* ─── HERO ENTRANCE ─── */
  const heroTl = gsap.timeline({ delay: 0.2 });
  heroTl
    .to('.hero-badge',         { autoAlpha: 1, scale: 1, duration: 0.6, ease: 'back.out(2.5)' })
    .to('.hero-title',         { autoAlpha: 1, y: 0, duration: 0.9, ease: 'power4.out' }, '-=0.25')
    .to('.hero-subtitle',      { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5')
    .to('.hero-actions .btn',  { autoAlpha: 1, y: 0, stagger: 0.14, duration: 0.55, ease: 'back.out(1.8)' }, '-=0.4')
    .to('.hero-stats',         { autoAlpha: 1, y: 0, scale: 1, duration: 0.55, ease: 'power3.out' }, '-=0.35');

  /* ─── 3D SHAPES FLOATING ─── */
  document.querySelectorAll('.shape-wrapper').forEach((shape, i) => {
    gsap.to(shape, {
      y: `random(-22, 22)`,
      x: `random(-10, 10)`,
      rotation: `random(-7, 7)`,
      duration: `random(4, 8)`,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      delay: i * 0.45,
    });
    gsap.to(shape, {
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1.5 },
      y: (i % 2 === 0 ? -1 : 1) * (90 + i * 30),
      autoAlpha: 0,
      ease: 'none',
    });
  });

  /* ─── HERO ORBS PARALLAX ─── */
  document.querySelectorAll('.hero-orb').forEach((orb, i) => {
    gsap.to(orb, {
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 },
      y: (i % 2 === 0 ? -140 : -70),
      ease: 'none',
    });
  });

  /* ─── TRUSTED BELT ─── */
  ScrollTrigger.create({
    trigger: '.trusted',
    start: 'top 92%',
    once: true,
    onEnter: () => gsap.fromTo('.trusted-label',
      { autoAlpha: 0, y: 16 },
      { autoAlpha: 1, y: 0, duration: 0.5, ease: 'power2.out', clearProps: 'all' }
    ),
  });

  /* ─── SECTION EYEBROW SCALE-IN ─── */
  document.querySelectorAll('.section-eyebrow').forEach(el => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 92%',
      once: true,
      onEnter: () => gsap.fromTo(el,
        { scaleX: 0, autoAlpha: 0 },
        { scaleX: 1, autoAlpha: 1, duration: 0.55, ease: 'power3.out', transformOrigin: 'center center', clearProps: 'all' }
      ),
    });
  });

  /* ─── SECTION TITLES WORD FLY-IN ─── */
  document.querySelectorAll('.section-title, .cta-title').forEach(title => {
    if (title.dataset.splitDone) return;
    title.dataset.splitDone = 'true';
    // Only split direct text nodes (leave child elements like .gradient-text untouched)
    const childNodes = Array.from(title.childNodes);
    childNodes.forEach(node => {
      if (node.nodeType !== Node.TEXT_NODE) return;
      const words = node.textContent.trim().split(/\s+/).filter(Boolean);
      if (!words.length) return;
      const frag = document.createDocumentFragment();
      words.forEach((w, idx) => {
        const outer = document.createElement('span');
        outer.style.cssText = 'display:inline-block;overflow:hidden;vertical-align:bottom;';
        const inner = document.createElement('span');
        inner.className = 'gsap-word';
        inner.style.display = 'inline-block';
        inner.textContent = w;
        outer.appendChild(inner);
        frag.appendChild(outer);
        if (idx < words.length - 1) frag.appendChild(document.createTextNode(' '));
      });
      title.replaceChild(frag, node);
    });
    // Also wrap .gradient-text words
    title.querySelectorAll('.gradient-text').forEach(gt => {
      const words = gt.textContent.trim().split(/\s+/).filter(Boolean);
      if (words.length <= 1) return;
      gt.innerHTML = words.map(w =>
        `<span style="display:inline-block;overflow:hidden;vertical-align:bottom;"><span class="gsap-word" style="display:inline-block;">${w}</span></span>`
      ).join(' ');
    });

    ScrollTrigger.create({
      trigger: title,
      start: 'top 94%',
      once: true,
      onEnter: () => gsap.fromTo(title.querySelectorAll('.gsap-word'),
        { y: '100%', opacity: 0, rotation: 3 },
        { y: '0%', opacity: 1, rotation: 0, duration: 0.42, stagger: 0.028, ease: 'power3.out', clearProps: 'all' }
      ),
    });
  });

  /* ─── BENTO CARDS — STAGGER FLIP-IN ─── */
  ScrollTrigger.create({
    trigger: '.services-bento',
    start: 'top 82%',
    once: true,
    onEnter: () => gsap.to('.bento-card', {
      autoAlpha: 1, y: 0, rotationX: 0,
      stagger: { amount: 0.55, from: 'start' },
      duration: 0.7, ease: 'power3.out', clearProps: 'transform,opacity,visibility',
    }),
  });

  /* ─── CAPABILITY CARDS — 3D SPIN-IN ─── */
  ScrollTrigger.create({
    trigger: '.cap-grid',
    start: 'top 82%',
    once: true,
    onEnter: () => gsap.to('.cap-card', {
      autoAlpha: 1, y: 0, scale: 1, rotationY: 0,
      stagger: 0.12,
      duration: 0.8, ease: 'back.out(1.4)', clearProps: 'transform,opacity,visibility',
    }),
  });

  /* ─── STAT CARDS — BOUNCE UP ─── */
  ScrollTrigger.create({
    trigger: '.stats-grid',
    start: 'top 82%',
    once: true,
    onEnter: () => gsap.to('.stat-card', {
      autoAlpha: 1, y: 0, scale: 1,
      stagger: 0.13,
      duration: 0.65, ease: 'back.out(2)', clearProps: 'transform,opacity,visibility',
    }),
  });

  /* ─── TESTIMONIALS — FLY IN FROM SIDES ─── */
  document.querySelectorAll('.testimonial-card').forEach((card, i) => {
    ScrollTrigger.create({
      trigger: card,
      start: 'top 88%',
      once: true,
      onEnter: () => gsap.to(card, {
        autoAlpha: 1, x: 0, y: 0, rotation: 0,
        duration: 0.8, ease: 'power3.out', clearProps: 'transform,opacity,visibility',
      }),
    });
  });

  /* ─── PROCESS STEPS — SEQUENTIAL SLIDE ─── */

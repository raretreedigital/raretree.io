  }

  /* ===== BENTO GRID ===== */
  .services-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .bento-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(148, 163, 184, 0.08);
    border-radius: 20px;
    padding: 32px;
    backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bento-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(20, 184, 166, 0.4), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bento-card:hover {
    border-color: rgba(20, 184, 166, 0.2);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(20, 184, 166, 0.06);
  }

  .bento-card:hover::after {
    opacity: 1;
  }

  .bento-large {
    grid-column: span 2;
  }

  .bento-wide {
    grid-column: span 2;
  }

  .bento-highlight {
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.1), rgba(139, 92, 246, 0.08));
    border-color: rgba(20, 184, 166, 0.2);
  }

  .bento-icon {
    width: 48px;
    height: 48px;
    color: #14b8a6;
    flex-shrink: 0;
  }

  .bento-icon svg {
    width: 100%;
    height: 100%;
  }

  .bento-icon-glow {
    filter: drop-shadow(0 0 12px rgba(20, 184, 166, 0.5));
  }

  .bento-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f1f5f9;
  }

  .bento-desc {
    font-size: 0.9rem;
    color: #94a3b8;
    line-height: 1.7;
    flex: 1;
  }

  .bento-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .bento-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #14b8a6;
    margin-top: 4px;
    transition: gap 0.2s ease;
  }

  .bento-link:hover {
    gap: 10px;
  }

  @media (max-width: 900px) {
    .services-bento { grid-template-columns: 1fr 1fr; }
    .bento-large, .bento-wide { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .services-bento { grid-template-columns: 1fr; }
    .bento-large, .bento-wide { grid-column: span 1; }
  }

  /* ===== STATS ===== */
  .stats-section {
    position: relative;
    overflow: hidden;
  }

  .stats-bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(20, 184, 166, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .stat-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(148, 163, 184, 0.08);
    border-radius: 20px;
    padding: 36px 28px;
    text-align: center;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #14b8a6, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .stat-card:hover {
    border-color: rgba(20, 184, 166, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  .stat-icon {
    width: 44px;
    height: 44px;
    margin: 0 auto 16px;
    color: #14b8a6;
    opacity: 0.8;
  }

  .stat-icon svg {
    width: 100%;
    height: 100%;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 900;
    color: #f1f5f9;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-suffix {
    font-size: 1rem;
    font-weight: 700;
    color: #14b8a6;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.8rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
  }

  /* ===== PROCESS ===== */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
    margin-top: 16px;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 32px 28px 32px 0;
    position: relative;
  }

  .process-num {
    font-size: 3rem;
    font-weight: 900;
    color: rgba(20, 184, 166, 0.2);
    letter-spacing: -0.04em;
    margin-bottom: 16px;
    line-height: 1;
  }

  .process-line {
    position: absolute;
    top: 56px;
    right: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(20, 184, 166, 0.3), transparent);

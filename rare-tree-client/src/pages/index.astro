---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Raretree Digital — AI Automation & Digital Transformation Agency"
  description="Raretree Digital helps businesses scale with AI automation, custom web & mobile apps, CRM/ERP implementation, and data-driven growth marketing. Book a free call today."
  keywords="AI automation agency, digital transformation, web app development, mobile app development, CRM implementation, growth marketing, Zoho partner, Salesforce partner"
  url="https://raretree.io/"
>

  <!-- ====== HERO ====== -->
  <section class="hero">
    <!-- Animated background orbs -->
    <div class="hero-orb orb-1"></div>
    <div class="hero-orb orb-2"></div>
    <div class="hero-orb orb-3"></div>
    <!-- Animated grid -->
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-content container">
      <div class="hero-badge reveal">
        <span class="badge badge-teal">
          <span class="badge-dot"></span>
          AI-Powered Automation Agency
        </span>
      </div>
      <h1 class="hero-title reveal delay-1">
        We Build Systems That<br/>
        <span class="gradient-text">Scale Your Business</span><br/>
        on Autopilot
      </h1>
      <p class="hero-subtitle reveal delay-2">
        Raretree Digital designs intelligent automation workflows, growth systems,
        and digital strategies that slash costs, amplify efficiency, and drive
        predictable revenue.
      </p>
      <div class="hero-actions reveal delay-3">
        <a href="/contact" class="btn btn-primary btn-lg">
          Book a Strategy Call
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/services" class="btn btn-secondary btn-lg">
          Explore Services
        </a>
      </div>
      <div class="hero-stats reveal delay-4">
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="50">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Projects</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="30">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Clients</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="95">0</span><span class="hero-stat-num">%</span>
          <span class="hero-stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Hero canvas animation -->
    <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  </section>

  <!-- ====== LOGOS / TRUSTED BY ====== -->
  <section class="trusted section-sm">
    <div class="container">
      <p class="trusted-label reveal">Trusted by growing businesses worldwide</p>
      <div class="trusted-track reveal delay-1">
        <div class="trusted-list">
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item">{name}</span>
          ))}
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item" aria-hidden="true">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== WHAT WE DO ====== -->
  <section class="section what-we-do">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">What We Do</span>
        <h2 class="section-title reveal delay-1">
          Full-Stack Digital <span class="gradient-text">Intelligence</span>
        </h2>
        <p class="section-subtitle reveal delay-2">
          We combine strategy, automation, and creative execution to build growth systems that work while you sleep.
        </p>
      </div>

      <div class="services-bento">
        <div class="bento-card bento-large reveal">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2a10 10 0 1 0 10 10M22 2l-5 5M17 2h5v5"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 9V7M12 17v-2M9 12H7M17 12h-2"/>
            </svg>
          </div>
          <h3 class="bento-title">AI Workflow Automation</h3>
          <p class="bento-desc">
            We map your operations, identify bottlenecks, and build intelligent automations that eliminate repetitive work, reduce errors, and scale your capacity — without adding headcount.
          </p>
          <div class="bento-tags">
            <span class="tag">n8n</span>
            <span class="tag">Zapier</span>
            <span class="tag">Custom AI</span>
            <span class="tag">LLMs</span>
          </div>
          <a href="/services" class="bento-link">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="bento-card reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 3v18h18"/>
              <path d="m7 16 4-4 4 4 5-5"/>
            </svg>
          </div>
          <h3 class="bento-title">Campaign Analytics</h3>
          <p class="bento-desc">From raw data to actionable insights — dashboards that tell you exactly where to invest and what's driving growth.</p>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="bento-title">Lead Generation</h3>
          <p class="bento-desc">AI-driven funnels, CRM automation, and targeted outreach systems that consistently deliver qualified leads at scale.</p>
        </div>

        <div class="bento-card bento-wide reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Commerce</h3>
          <p class="bento-desc">Mobile-optimized Shopify stores built for conversion — from product pages to checkout, every pixel earns its place.</p>
          <div class="bento-tags">
            <span class="tag">Shopify</span>
            <span class="tag">CRO</span>
            <span class="tag">UX/UI</span>
          </div>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="bento-title">Consulting & Strategy</h3>
          <p class="bento-desc">Deep-dive strategy sessions that align your tools, team, and technology with real business outcomes.</p>
        </div>

        <div class="bento-card bento-highlight reveal delay-3">
          <div class="bento-icon bento-icon-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Marketing</h3>
          <p class="bento-desc">SEO, PPC, social media — integrated campaigns that build awareness and convert traffic into revenue.</p>
          <div class="bento-tags">
            <span class="tag">SEO</span>
            <span class="tag">PPC</span>
            <span class="tag">Social</span>
          </div>
        </div>

        <div class="bento-card bento-large bento-ai-ml reveal delay-1">
          <div class="bento-ai-orb"></div>
          <div class="bento-icon bento-icon-glow" style="color:#a855f7">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
            </svg>
          </div>
          <h3 class="bento-title">AI & ML Development</h3>
          <p class="bento-desc">
            From custom LLM fine-tuning to computer vision and predictive models — we build production-grade AI systems that deliver real business intelligence.
          </p>
          <div class="bento-tags">
            <span class="tag" style="color:#a855f7;border-color:rgba(168,85,247,0.3);background:rgba(168,85,247,0.1)">PyTorch</span>
            <span class="tag" style="color:#f97316;border-color:rgba(249,115,22,0.3);background:rgba(249,115,22,0.1)">TensorFlow</span>
            <span class="tag" style="color:#14b8a6;border-color:rgba(20,184,166,0.3);background:rgba(20,184,166,0.1)">LangChain</span>
            <span class="tag" style="color:#f1f5f9;border-color:rgba(241,245,249,0.2);background:rgba(241,245,249,0.06)">OpenAI</span>
          </div>
          <a href="/services" class="bento-link" style="color:#a855f7">
            Build AI →
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon" style="color:#f59e0b">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              <path d="M11 8v3m0 3h.01"/>
            </svg>
          </div>
          <h3 class="bento-title">SEO Optimization</h3>
          <p class="bento-desc">Technical SEO, keyword dominance, and content strategy that drives organic traffic compounding month over month.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#f59e0b;border-color:rgba(245,158,11,0.3);background:rgba(245,158,11,0.08)">Technical SEO</span>
            <span class="tag" style="color:#f59e0b;border-color:rgba(245,158,11,0.3);background:rgba(245,158,11,0.08)">Core Web Vitals</span>
          </div>
        </div>

        <div class="bento-card reveal delay-3">
          <div class="bento-icon" style="color:#ec4899">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="m12 20 7-7-7-7"/><path d="M5 20V4"/>
            </svg>
          </div>
          <h3 class="bento-title">Branding & Creative</h3>
          <p class="bento-desc">Logos, brand identity systems, copywriting, and visual storytelling that makes your brand impossible to ignore.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#ec4899;border-color:rgba(236,72,153,0.3);background:rgba(236,72,153,0.08)">Brand Identity</span>
            <span class="tag" style="color:#ec4899;border-color:rgba(236,72,153,0.3);background:rgba(236,72,153,0.08)">Design</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CAPABILITIES ====== -->
  <section class="section cap-section">
    <div class="cap-bg" aria-hidden="true">
      <div class="cap-orb cap-orb-1"></div>
      <div class="cap-orb cap-orb-2"></div>
      <div class="cap-grid-lines"></div>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">What We Build</span>
        <h2 class="section-title reveal delay-1">Six Ways We <span class="gradient-text">Move the Needle</span></h2>
        <p class="section-subtitle reveal delay-2">Every engagement draws from our full capability stack — strategy, execution, and engineering working as one.</p>
      </div>

      <div class="cap-grid reveal delay-1">

        <div class="cap-card" data-tilt>
          <div class="cap-card-glow" style="--cg:#06d6c4"></div>
          <div class="cap-icon" style="--ci:#06d6c4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="cap-title">Web Applications</h3>
          <p class="cap-desc">Fast, scalable web products — React, Next.js, Vue, Nuxt, Svelte paired with resilient backends in Spring Boot, FastAPI, Express, Elysia or Gin.</p>
          <div class="cap-stack">
            <span>React</span><span>Next.js</span><span>Vue</span><span>FastAPI</span><span>Spring Boot</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

        <div class="cap-card" data-tilt>
          <div class="cap-card-glow" style="--cg:#3b82f6"></div>
          <div class="cap-icon" style="--ci:#3b82f6">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          </div>
          <h3 class="cap-title">Mobile Apps</h3>
          <p class="cap-desc">iOS + Android — beautifully crafted, offline-capable apps with real-time sync, push notifications, and App Store/Play Store deployment.</p>
          <div class="cap-stack">
            <span>React Native</span><span>Flutter</span><span>Swift</span><span>Kotlin</span><span>Firebase</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

        <div class="cap-card cap-card-featured" data-tilt>
          <div class="cap-card-glow" style="--cg:#a855f7"></div>
          <div class="cap-icon" style="--ci:#a855f7">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M12 2a10 10 0 1 0 10 10M22 2l-5 5M17 2h5v5"/><circle cx="12" cy="12" r="3"/><path d="M12 9V7M12 17v-2M9 12H7M17 12h-2"/></svg>
          </div>
          <h3 class="cap-title">AI & Automation</h3>
          <p class="cap-desc">LLM fine-tuning, RAG pipelines, computer vision, and n8n / Zapier automation workflows that eliminate manual work and run around the clock.</p>
          <div class="cap-stack">
            <span>OpenAI</span><span>LangChain</span><span>PyTorch</span><span>n8n</span><span>Zapier</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

        <div class="cap-card" data-tilt>
          <div class="cap-card-glow" style="--cg:#f59e0b"></div>
          <div class="cap-icon" style="--ci:#f59e0b">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="cap-title">Growth & Sales</h3>
          <p class="cap-desc">Full-funnel growth strategy, paid acquisition, CRM-powered sales pipelines, and retention systems that compound month over month.</p>
          <div class="cap-stack">
            <span>Meta Ads</span><span>Google Ads</span><span>HubSpot</span><span>SEO</span><span>CRO</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

        <div class="cap-card" data-tilt>
          <div class="cap-card-glow" style="--cg:#e8441a"></div>
          <div class="cap-icon" style="--ci:#e8441a">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="cap-title">CRM & ERP Systems</h3>
          <p class="cap-desc">End-to-end Zoho, Salesforce, and Odoo deployments — custom modules, automation workflows, and full ecosystem integrations that run your business.</p>
          <div class="cap-stack">
            <span>Zoho</span><span>Salesforce</span><span>Odoo</span><span>WhatsApp API</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

        <div class="cap-card" data-tilt>
          <div class="cap-card-glow" style="--cg:#06b6d4"></div>
          <div class="cap-icon" style="--ci:#06b6d4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 5-5"/></svg>
          </div>
          <h3 class="cap-title">Data & Analytics</h3>
          <p class="cap-desc">Custom dashboards, multi-channel attribution, and predictive analytics that turn raw data into decisions — and decisions into revenue.</p>
          <div class="cap-stack">
            <span>BigQuery</span><span>Looker</span><span>Python</span><span>Metabase</span><span>Power BI</span>
          </div>
          <div class="cap-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ====== STATS ====== -->
  <section class="section stats-section">
    <div class="stats-bg-glow"></div>
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">Our Impact</span>
        <h2 class="section-title reveal delay-1">Numbers That <span class="gradient-text">Matter</span></h2>
      </div>
      <div class="stats-grid">
        <div class="stat-card reveal delay-1">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div class="stat-number counter" data-target="50">0</div>
          <div class="stat-suffix">+ Projects</div>
          <div class="stat-label">Successfully Delivered</div>
        </div>
        <div class="stat-card reveal delay-2">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="stat-number counter" data-target="30">0</div>
          <div class="stat-suffix">+ Clients</div>
          <div class="stat-label">Across Industries</div>
        </div>
        <div class="stat-card reveal delay-3">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <div class="stat-number counter" data-target="95">0</div>
          <div class="stat-suffix">% Satisfaction</div>
          <div class="stat-label">Client Retention Rate</div>
        </div>
        <div class="stat-card reveal delay-4">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="stat-number counter" data-target="3">0</div>
          <div class="stat-suffix">x ROI</div>
          <div class="stat-label">Average Return on Investment</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PROCESS ====== -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">How It Works</span>
        <h2 class="section-title reveal delay-1">From Idea to <span class="gradient-text">Execution</span></h2>
        <p class="section-subtitle reveal delay-2">Our battle-tested 4-step process that turns your goals into measurable results.</p>
      </div>
      <div class="process-steps">
        <div class="process-step reveal delay-1">
          <div class="process-num">01</div>
          <div class="process-line"></div>
          <div class="process-body">
            <h3>Discovery Call</h3>
            <p>We dive deep into your business goals, pain points, and opportunities to map a clear path forward.</p>
          </div>
        </div>
        <div class="process-step reveal delay-2">
          <div class="process-num">02</div>
          <div class="process-line"></div>
          <div class="process-body">
            <h3>Strategy Design</h3>
            <p>We craft a tailored automation and growth strategy aligned with your KPIs and budget.</p>
          </div>
        </div>
        <div class="process-step reveal delay-3">
          <div class="process-num">03</div>
          <div class="process-line"></div>
          <div class="process-body">
            <h3>Build & Deploy</h3>
            <p>Our team builds, tests, and launches your systems with precision — on time, every time.</p>
          </div>
        </div>
        <div class="process-step reveal delay-4">
          <div class="process-num">04</div>
          <div class="process-body">
            <h3>Optimize & Scale</h3>
            <p>We monitor performance, iterate rapidly, and scale what works to maximize your ROI.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TESTIMONIALS ====== -->
  <section class="section testimonials-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">Testimonials</span>
        <h2 class="section-title reveal delay-1">What Our <span class="gradient-text">Clients Say</span></h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card reveal delay-1">
          <div class="testimonial-quote">"</div>
          <p class="testimonial-text">Raretree transformed our patient onboarding workflow. We went from 6-hour manual data entry to a fully automated pipeline in under 2 weeks. Results were immediate and remarkable.</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">CE</div>
            <div>
              <div class="testimonial-name">— CEO, Private Clinic</div>
              <div class="testimonial-role">Healthcare</div>
            </div>
          </div>
          <div class="testimonial-stars">★★★★★</div>

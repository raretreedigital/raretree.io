  const decorData = [
    { parent: '.what-we-do',          pos: 'right:2%;top:10%;opacity:0.22;',    size: 180, color: '6,214,196' },
    { parent: '.stats-section',       pos: 'left:1%;bottom:5%;opacity:0.17;',   size: 140, color: '168,85,247' },
    { parent: '.testimonials-section',pos: 'right:3%;bottom:10%;opacity:0.15;', size: 120, color: '99,179,255' },
  ];
  decorData.forEach(d => {
    const sec = document.querySelector(d.parent);
    if (!sec) return;
    const wrap = document.createElement('div');
    wrap.className = 'section-float-decor';

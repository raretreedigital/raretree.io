  .testimonial-text {
    font-size: 0.92rem;
    color: #94a3b8;
    line-height: 1.75;
    margin-bottom: 24px;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, #14b8a6, #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }

  .testimonial-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: #f1f5f9;
  }

  .testimonial-role {
    font-size: 0.78rem;
    color: #64748b;
    margin-top: 2px;
  }

  .testimonial-stars {
    font-size: 0.85rem;
    color: #f59e0b;
    letter-spacing: 2px;
  }

  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: 1fr; }
  }

  /* ===== CTA ===== */
  .cta-section {
    padding: 120px 0;
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse at center, rgba(15, 23, 42, 0.8) 0%, #030712 100%);
  }

  .cta-glow-1 {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(20, 184, 166, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-glow-2 {
    position: absolute;
    top: 20%;
    right: 10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 28px;
    padding: 80px 60px;
    text-align: center;
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(20, 184, 166, 0.5), transparent);
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #f1f5f9;
    margin: 12px 0 20px;
    line-height: 1.15;
  }

  .cta-subtitle {
    color: #94a3b8;
    font-size: 1rem;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 600px) {
    .cta-inner { padding: 48px 28px; }
  }

  /* ===== BENTO AI/ML ===== */
  .bento-ai-ml {
    background: linear-gradient(135deg, rgba(168,85,247,0.08), rgba(20,184,166,0.05));
    border-color: rgba(168,85,247,0.2);
    overflow: hidden;
  }
  .bento-ai-orb {
    position: absolute;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(168,85,247,0.25) 0%, transparent 70%);
    top: -60px; right: -60px;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
    animation: floatOrb 8s ease-in-out infinite;
  }

  /* ===== CAPABILITIES SECTION ===== */
  .cap-section {
    position: relative;
    overflow: hidden;
  }

  .cap-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cap-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: floatOrb 11s ease-in-out infinite;
  }

  .cap-orb-1 {
    width: 500px; height: 400px;
    background: radial-gradient(circle, rgba(168,85,247,0.13) 0%, transparent 70%);
    top: -80px; left: -100px;
  }

  .cap-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(6,214,196,0.11) 0%, transparent 70%);
    bottom: -80px; right: -60px;
    animation-delay: 5s;
  }

  .cap-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(6,214,196,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6,214,196,0.025) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    perspective: 1200px;
  }

  .cap-card {
    position: relative;
    background: rgba(10, 22, 40, 0.6);
    border: 1px solid rgba(120,160,200,0.1);
    border-radius: 20px;
    padding: 30px 28px 28px;
    backdrop-filter: blur(14px);
    overflow: hidden;
    cursor: default;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .cap-card:hover {
    border-color: rgba(var(--cg-r,6),var(--cg-g,214),var(--cg-b,196),0.3);
    box-shadow:
      0 24px 64px rgba(0,0,0,0.45),
      0 0 40px rgba(var(--cg-r,6),var(--cg-g,214),var(--cg-b,196),0.1);
  }

  .cap-card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 0%, color-mix(in srgb, var(--cg) 14%, transparent) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .cap-card:hover .cap-card-glow {
    opacity: 1;
  }

  .cap-card-featured {
    grid-column: span 1;
    background: linear-gradient(135deg, rgba(168,85,247,0.08), rgba(10,22,40,0.7));
    border-color: rgba(168,85,247,0.2);
  }

  .cap-icon {
    width: 52px; height: 52px;
    background: color-mix(in srgb, var(--ci) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--ci) 30%, transparent);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ci);
    margin-bottom: 18px;
    transition: box-shadow 0.3s ease;
  }

  .cap-card:hover .cap-icon {
    box-shadow: 0 0 24px color-mix(in srgb, var(--ci) 35%, transparent);
  }

  .cap-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e8f0ff;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .cap-desc {
    font-size: 0.85rem;
    color: #607898;
    line-height: 1.7;
    margin-bottom: 18px;
    flex: 1;
  }

  .cap-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
  }

  .cap-stack span {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #4d6480;
    background: rgba(120,160,200,0.07);
    border: 1px solid rgba(120,160,200,0.12);
    padding: 3px 10px;
    border-radius: 100px;
    text-transform: uppercase;
  }

  .cap-arrow {
    color: #3a5270;
    transition: all 0.25s ease;
    display: inline-flex;
  }

  .cap-card:hover .cap-arrow {
    color: var(--ci, #06d6c4);
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .cap-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .cap-grid { grid-template-columns: 1fr; }
  }

  /* ===== BENTO CARD SPOTLIGHT GLOW (cursor-tracking) ===== */
  .bento-card {
    --mx: 50%;
    --my: 50%;
  }
  .bento-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx) var(--my), rgba(6,214,196,0.11) 0%, transparent 52%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    border-radius: inherit;
    z-index: 0;
  }
  .bento-card:hover::before { opacity: 1; }
  .bento-card > * { position: relative; z-index: 1; }

  /* bento icon jolts on hover */
  .bento-card:hover .bento-icon svg {
    animation: iconJolt 0.45s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes iconJolt {
    0%   { transform: scale(1) rotate(0deg); }
    30%  { transform: scale(1.22) rotate(-10deg); }
    65%  { transform: scale(0.94) rotate(5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  /* ===== STAT CARD ENHANCED HOVER ===== */
  .stat-card:hover {
    border-color: rgba(6,214,196,0.28);
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 24px 64px rgba(0,0,0,0.45), 0 0 50px rgba(6,214,196,0.1);
  }
  .stat-card:hover .stat-number {
    color: #ffffff;
    text-shadow: 0 0 30px rgba(6,214,196,0.55), 0 0 70px rgba(6,214,196,0.2);
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .stat-card:hover .stat-icon {
    color: #06d6c4;
    opacity: 1;
    animation: statIconSpin 0.65s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes statIconSpin {
    0%   { transform: rotate(0deg) scale(1); }
    45%  { transform: rotate(200deg) scale(1.25); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ===== PROCESS STEP HOVER ===== */
  .process-step {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .process-step:hover {
    transform: translateX(10px);
  }
  .process-num {
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .process-step:hover .process-num {
    color: rgba(6,214,196,0.75);
    text-shadow: 0 0 32px rgba(6,214,196,0.45);
  }
  .process-body h3 {
    transition: color 0.3s ease;
  }
  .process-step:hover .process-body h3 {
    color: #06d6c4;
  }

  /* ===== TESTIMONIAL CARD — disable translateY to let JS tilt take over ===== */
  .testimonial-card {
    transform-style: preserve-3d;
    will-change: transform;
    transition: border-color 0.3s ease, box-shadow 0.3s ease !important;
  }

    wrap.innerHTML = `<svg width="${d.size}" height="${d.size}" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="50" cy="50" rx="45" ry="45" stroke="rgba(${d.color},0.5)" stroke-width="0.8"/>
      <ellipse cx="50" cy="50" rx="45" ry="18" stroke="rgba(${d.color},0.3)" stroke-width="0.7"/>
      <ellipse cx="50" cy="50" rx="18" ry="45" stroke="rgba(${d.color},0.3)" stroke-width="0.7"/>
      <line x1="5" y1="50" x2="95" y2="50" stroke="rgba(${d.color},0.2)" stroke-width="0.6"/>
      <line x1="50" y1="5" x2="50" y2="95" stroke="rgba(${d.color},0.2)" stroke-width="0.6"/>

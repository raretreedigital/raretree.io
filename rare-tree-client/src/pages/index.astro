  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 64px;

<script>
  // Counter animation
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0');
    const duration = 1800;
    const step = target / (duration / 16);
    let current = 0;

    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      el.textContent = Math.floor(current).toString();
    }, 16);
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        animateCounter(el);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.counter, [data-target]').forEach(el => {
    counterObserver.observe(el as HTMLElement);
  });

  // ===== Tech Stack Tab Switcher =====
  const tsTabs = document.querySelectorAll<HTMLButtonElement>('.ts-tab');
  const tsPanels = document.querySelectorAll<HTMLElement>('.ts-panel');

  tsTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tsTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      tsPanels.forEach(p => {
        p.classList.remove('ts-panel-active');
        if (p.id === `panel-${target}`) {
          p.classList.add('ts-panel-active');
          // Animate skill bars in newly shown panel
          p.querySelectorAll('.ts-tech-fill').forEach((fill: Element) => {
            const el = fill as HTMLElement;
            el.style.width = '0';
            setTimeout(() => { el.style.width = el.style.getPropertyValue('--w') || '80%'; }, 50);
          });
        }
      });
    });
  });

  // Animate skill bars when section enters view
  const tsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.ts-tech-fill').forEach((fill: Element) => {
          const el = fill as HTMLElement;
          el.style.width = el.style.getPropertyValue('--w') || '80%';
        });
        tsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  const tsSection = document.querySelector('.tech-stack-section');
  if (tsSection) tsObserver.observe(tsSection);
</script>


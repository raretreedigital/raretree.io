  });

  /* ─── INTERACTIVE HERO SHAPES ─── */
  (function () {
    const heroEl = document.querySelector('.hero');
    if (!heroEl) return;
    const iShapes = Array.from(document.querySelectorAll('.shape-wrapper[data-interactive]'));
    const animating = new Set();

    // Enable pointer events on individual shapes (overrides parent pointer-events:none)
    iShapes.forEach(shape => {
      shape.style.pointerEvents = 'auto';
      shape.style.cursor = 'pointer';
    });

    // Track mouse over the hero and tilt shapes toward cursor
    heroEl.addEventListener('mousemove', (e) => {
      const hr = heroEl.getBoundingClientRect();
      const mx = e.clientX - hr.left;
      const my = e.clientY - hr.top;

      iShapes.forEach(shape => {
        if (animating.has(shape)) return;
        const sr = shape.getBoundingClientRect();
        const sx = sr.left + sr.width  / 2 - hr.left;
        const sy = sr.top  + sr.height / 2 - hr.top;
        const dx = mx - sx;
        const dy = my - sy;
        const dist = Math.hypot(dx, dy);
        const MAX = 280;
        if (dist < MAX) {
          const inf = 1 - dist / MAX;
          gsap.to(shape, {
            rotationX:  (dy / MAX) *  28 * inf,
            rotationY: -(dx / MAX) *  28 * inf,
            scale: 1 + inf * 0.25,
            filter: `brightness(${(1 + inf * 0.9).toFixed(2)}) drop-shadow(0 0 ${Math.round(14 * inf)}px rgba(6,214,196,0.8))`,
            duration: 0.22, ease: 'power2.out', overwrite: 'auto',
          });
        } else {
          gsap.to(shape, {
            rotationX: 0, rotationY: 0, scale: 1, filter: 'brightness(1)',
            duration: 0.55, ease: 'elastic.out(1, 0.6)', overwrite: 'auto',
          });
        }
      });

      // Hologram tilt toward mouse
      const holo = document.querySelector('.hero-hologram');
      if (holo) {
        const hx = (mx / hr.width  - 0.5) * 22;
        const hy = (my / hr.height - 0.5) * 14;
        gsap.to(holo, { rotationY: hx, rotationX: -hy, duration: 0.5, ease: 'power2.out', overwrite: 'auto' });
      }

      // Subtle hero-content parallax depth
      gsap.to('.hero-content', {
        x: (mx / hr.width  - 0.5) * 10,
        y: (my / hr.height - 0.5) *  5,
        duration: 0.9, ease: 'power2.out', overwrite: 'auto',
      });
    });

    heroEl.addEventListener('mouseleave', () => {
      gsap.to(iShapes, { rotationX: 0, rotationY: 0, scale: 1, filter: 'brightness(1)', duration: 0.8, stagger: 0.04, ease: 'elastic.out(1, 0.5)' });
      gsap.to('.hero-hologram', { rotationX: 0, rotationY: 0, duration: 0.8, ease: 'elastic.out(1, 0.5)' });
      gsap.to('.hero-content',  { x: 0, y: 0, duration: 0.6, ease: 'power2.out' });
    });

    // Click a shape → spin + particle burst
    const BURST_COLORS = ['#06d6c4', '#a855f7', '#63b3ff', '#f59e0b', '#ff5a5a'];
    // Per-shape: drag+throw+shatter+flee+hover glow
    iShapes.forEach(shape => {
      let isDragging = false;
      let startClientX = 0, startClientY = 0;
      let lastClientX = 0, lastClientY = 0, lastT = 0;
      let velX = 0, velY = 0;
      let dblTimer = null;
      let clickCount = 0;

      // ── Hover glow ──
      shape.addEventListener('mouseenter', () => {
        if (!animating.has(shape) && !isDragging)
          gsap.to(shape, { filter: 'brightness(1.8) drop-shadow(0 0 20px rgba(6,214,196,0.95))', duration: 0.22, overwrite: 'auto' });
      });
      shape.addEventListener('mouseleave', () => {
        if (!isDragging)
          gsap.to(shape, { filter: 'brightness(1)', duration: 0.35, overwrite: 'auto' });
      });

      // ── Drag + throw with velocity ──
      shape.addEventListener('pointerdown', (e) => {
        if (e.button === 2) return;
        isDragging = true;
        shape.setPointerCapture(e.pointerId);
        gsap.killTweensOf(shape, 'x,y');
        startClientX = e.clientX - (parseFloat(gsap.getProperty(shape, 'x')) || 0);
        startClientY = e.clientY - (parseFloat(gsap.getProperty(shape, 'y')) || 0);
        lastClientX = e.clientX; lastClientY = e.clientY; lastT = Date.now();
        velX = 0; velY = 0;
        shape.classList.add('is-dragging');
        gsap.to(shape, { scale: 1.5, zIndex: 100, filter: 'brightness(2.2) drop-shadow(0 0 28px rgba(6,214,196,1))', duration: 0.18 });
        e.preventDefault();
      });

      shape.addEventListener('pointermove', (e) => {
        if (!isDragging) return;
        const now = Date.now();
        const dt = Math.max(now - lastT, 1);
        velX = (e.clientX - lastClientX) / dt;
        velY = (e.clientY - lastClientY) / dt;
        lastClientX = e.clientX; lastClientY = e.clientY; lastT = now;
        gsap.set(shape, { x: e.clientX - startClientX, y: e.clientY - startClientY });
        // Comet trail dot
        const d = document.createElement('div');
        const col = ['6,214,196','168,85,247','99,179,255'][Math.floor(Math.random()*3)];
        d.style.cssText = `position:fixed;width:7px;height:7px;border-radius:50%;background:rgba(${col},0.75);box-shadow:0 0 10px rgba(${col},0.6);pointer-events:none;z-index:9997;left:${e.clientX-3.5}px;top:${e.clientY-3.5}px;transform:translate(-50%,-50%);`;
        document.body.appendChild(d);
        gsap.to(d, { scale: 0.1, autoAlpha: 0, duration: 0.55, ease: 'power2.out', onComplete: () => d.remove() });
      });

      shape.addEventListener('pointerup', (e) => {
        if (!isDragging) return;
        isDragging = false;
        shape.classList.remove('is-dragging');
        const cx = parseFloat(gsap.getProperty(shape, 'x')) || 0;
        const cy = parseFloat(gsap.getProperty(shape, 'y')) || 0;
        const throwDist = Math.hypot(velX, velY) * 140;
        const throwX = cx + velX * throwDist;
        const throwY = cy + velY * throwDist;
        gsap.timeline()
          .to(shape, { x: throwX, y: throwY, scale: 1.15, duration: 0.38, ease: 'power2.out' })
          .to(shape, { x: 0, y: 0, scale: 1, rotationX: 0, rotationY: 0, filter: 'brightness(1)', zIndex: 'auto', duration: 1.35, ease: 'elastic.out(1, 0.45)' });
      });

      // ── Click (single): particle burst, double: shatter ──
      shape.addEventListener('click', (e) => {
        if (isDragging) return;
        clickCount++;
        if (dblTimer) clearTimeout(dblTimer);
        dblTimer = setTimeout(() => {
          if (clickCount === 1) {
            // Single click — spin burst
            if (animating.has(shape)) { clickCount = 0; return; }
            animating.add(shape);
            gsap.timeline({ onComplete: () => animating.delete(shape) })
              .to(shape, { rotationY: '+=540', rotationX: '+=270', scale: 1.9, duration: 0.4, ease: 'power3.in' })
              .to(shape, { rotationY: 0, rotationX: 0, scale: 1, duration: 1.0, ease: 'elastic.out(1.2, 0.45)' });
            const sr = shape.getBoundingClientRect();
            const pcx = sr.left + sr.width/2, pcy = sr.top + sr.height/2;
            for (let i = 0; i < 20; i++) {
              const p = document.createElement('div');
              const col = BURST_COLORS[Math.floor(Math.random() * BURST_COLORS.length)];
              const sz = 3 + Math.random() * 7;
              p.style.cssText = `position:fixed;width:${sz}px;height:${sz}px;border-radius:${Math.random()>.5?'50%':'2px'};background:${col};box-shadow:0 0 ${sz*2}px ${col};pointer-events:none;z-index:9999;left:${pcx}px;top:${pcy}px;transform:translate(-50%,-50%);`;
              document.body.appendChild(p);
              const ang = (i/20)*Math.PI*2 + Math.random()*0.5;
              const dist = 50 + Math.random() * 100;
              gsap.to(p, { x: Math.cos(ang)*dist, y: Math.sin(ang)*dist - Math.random()*40, autoAlpha: 0, scale: 0, duration: 0.45+Math.random()*0.5, ease: 'power2.out', delay: Math.random()*0.06, onComplete:()=>p.remove() });
            }
            gsap.fromTo(shape, { filter: 'brightness(5) saturate(3)' }, { filter: 'brightness(1)', duration: 0.45 });
          } else if (clickCount >= 2) {
            // Double click — SHATTER and reassemble
            gsap.killTweensOf(shape);
            const sr = shape.getBoundingClientRect();
            const cx = sr.left + sr.width/2, cy = sr.top + sr.height/2;
            gsap.to(shape, { autoAlpha: 0, scale: 0, duration: 0.12, ease: 'power3.in' });
            for (let i = 0; i < 16; i++) {
              const f = document.createElement('div');
              const col = BURST_COLORS[Math.floor(Math.random() * BURST_COLORS.length)];
              const sz = 3 + Math.random() * 9;
              f.style.cssText = `position:fixed;width:${sz}px;height:${sz}px;background:${col};box-shadow:0 0 ${sz*3}px ${col};pointer-events:none;z-index:9999;left:${cx}px;top:${cy}px;border-radius:${Math.random()>.5?'50%':'3px'};transform:translate(-50%,-50%);`;
              document.body.appendChild(f);
              const ang = (i/16)*Math.PI*2 + Math.random()*0.8;
              const dist = 30 + Math.random()*110;
              gsap.to(f, { x: Math.cos(ang)*dist, y: Math.sin(ang)*dist, rotation: Math.random()*720-360, autoAlpha: 0, scale: 0.1, duration: 0.55+Math.random()*0.45, ease: 'power2.out', onComplete:()=>f.remove() });
            }
            // Screen shake
            gsap.to('.hero-content', { x: 6, duration: 0.05, yoyo: true, repeat: 5, ease: 'none', onComplete: () => gsap.set('.hero-content', { x: 0 }) });
            setTimeout(() => gsap.fromTo(shape, { autoAlpha: 0, scale: 0, rotation: -360 }, { autoAlpha: 1, scale: 1, rotation: 0, duration: 0.9, ease: 'back.out(2.5)' }), 750);
          }
          clickCount = 0;
        }, 260);
      });

      // ── Right-click flee ──
      shape.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        if (isDragging) return;
        gsap.killTweensOf(shape, 'x,y');
        const hr = heroEl.getBoundingClientRect();
        const rx = (Math.random() - 0.5) * hr.width * 0.55;
        const ry = (Math.random() - 0.5) * hr.height * 0.45;
        const spinDir = Math.random() > 0.5 ? 1 : -1;
        gsap.timeline()
          .to(shape, { x: rx, y: ry, scale: 1.4, rotationZ: spinDir * (120 + Math.random()*180), filter: 'brightness(2.5) drop-shadow(0 0 22px rgba(168,85,247,0.9))', duration: 0.28, ease: 'power4.out' })
          .to(shape, { x: 0, y: 0, scale: 1, rotationZ: 0, filter: 'brightness(1)', duration: 1.6, ease: 'elastic.out(1, 0.4)', delay: 0.4 });
      });
    });

    // Hologram rings continuous spin
    gsap.to('.holo-r1', { rotation:  360, duration: 9,  repeat: -1, ease: 'none', transformOrigin: '50% 50%' });
    gsap.to('.holo-r2', { rotation: -360, duration: 14, repeat: -1, ease: 'none', transformOrigin: '50% 50%' });
    gsap.to('.holo-r3', { rotation:  360, duration: 20, repeat: -1, ease: 'none', transformOrigin: '50% 50%' });
    gsap.to('.holo-r4', { rotation: -360, duration: 28, repeat: -1, ease: 'none', transformOrigin: '50% 50%' });
    gsap.to('.holo-grid', { rotation: 360, duration: 60, repeat: -1, ease: 'none', transformOrigin: '50% 50%' });
    gsap.to('.holo-equator', { scaleX: 1.25, duration: 2.8, repeat: -1, yoyo: true, ease: 'sine.inOut' });
    gsap.to('.holo-core', { scale: 1.35, boxShadow: '0 0 40px rgba(6,214,196,0.9)', duration: 1.8, repeat: -1, yoyo: true, ease: 'sine.inOut' });
    gsap.fromTo('.hero-hologram-wrap', { autoAlpha: 0, scale: 0.7 }, { autoAlpha: 1, scale: 1, duration: 1.4, ease: 'back.out(1.8)', delay: 1.0 });
  })();

  /* ─── GLITCH TEXT ON HERO TITLE HOVER ─── */
  const heroTitle = document.querySelector('.hero-title');
  if (heroTitle) {
    let glitchTimer;
    heroTitle.style.cursor = 'default';
    heroTitle.addEventListener('mouseenter', () => {
      let n = 0;
      glitchTimer = setInterval(() => {

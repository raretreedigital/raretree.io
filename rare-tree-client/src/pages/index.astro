  /* ─── STAR TRAIL on SCROLL (section dividers) ─── */
  document.querySelectorAll('.divider').forEach(div => {
    gsap.fromTo(div,
      { scaleX: 0, transformOrigin: 'left center' },
      {
        scaleX: 1, duration: 1.2, ease: 'power2.inOut',
        scrollTrigger: { trigger: div, start: 'top 90%', once: true },
      }
    );
  });

  /* ─── CAP CARD ICON SPIN ON SCROLL ENTER ─── */
  ScrollTrigger.create({
    trigger: '.cap-grid', start: 'top 82%', once: true,
    onEnter: () => {
      document.querySelectorAll('.cap-icon').forEach((icon, i) => {
        gsap.fromTo(icon,
          { rotation: -180, scale: 0, autoAlpha: 0 },
          { rotation: 0, scale: 1, autoAlpha: 1, duration: 0.7, delay: i * 0.1, ease: 'back.out(2)', clearProps: 'all' }
        );
      });
    },
  });

  /* ─── STAT NUMBER BOUNCE SCALE ─── */
  ScrollTrigger.create({
    trigger: '.stats-grid', start: 'top 82%', once: true,
    onEnter: () => {
      document.querySelectorAll('.stat-number').forEach((num, i) => {
        gsap.fromTo(num,
          { scale: 0.3, autoAlpha: 0 },
          { scale: 1, autoAlpha: 1, duration: 0.8, delay: i * 0.12, ease: 'elastic.out(1.2, 0.5)', clearProps: 'all' }
        );
      });
    },
  });

  ScrollTrigger.refresh();
})();
</script>


    onEnter: () => gsap.fromTo('.process-line',
      { scaleX: 0, transformOrigin: 'left center', autoAlpha: 0 },
      { scaleX: 1, autoAlpha: 1, duration: 1.3, ease: 'power2.inOut', stagger: 0.28, delay: 0.25, clearProps: 'all' }
    ),
  });


---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Raretree | AI Automation & Digital Transformation">

  <!-- ====== HERO ====== -->
  <section class="hero">
    <!-- Animated background orbs -->
    <div class="hero-orb orb-1"></div>
    <div class="hero-orb orb-2"></div>
    <div class="hero-orb orb-3"></div>
    <!-- Animated grid -->
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-content container">
      <div class="hero-badge reveal">
        <span class="badge badge-teal">
          <span class="badge-dot"></span>
          AI-Powered Automation Agency
        </span>
      </div>
      <h1 class="hero-title reveal delay-1">
        We Build Systems That<br/>
        <span class="gradient-text">Scale Your Business</span><br/>
        on Autopilot
      </h1>
      <p class="hero-subtitle reveal delay-2">
        Raretree Digital designs intelligent automation workflows, growth systems,
        and digital strategies that slash costs, amplify efficiency, and drive
        predictable revenue.
      </p>
      <div class="hero-actions reveal delay-3">
        <a href="/contact" class="btn btn-primary btn-lg">
          Book a Strategy Call
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/services" class="btn btn-secondary btn-lg">
          Explore Services
        </a>
      </div>
      <div class="hero-stats reveal delay-4">
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="50">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Projects</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="30">0</span><span class="hero-stat-num">+</span>
          <span class="hero-stat-label">Clients</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="95">0</span><span class="hero-stat-num">%</span>
          <span class="hero-stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Floating tech tags -->
    <div class="hero-float-tags">
      <span class="float-tag ftag-react" style="--delay: 0s; --x: 7%; --y: 28%;">⚛ React</span>
      <span class="float-tag ftag-next" style="--delay: 1.2s; --x: 87%; --y: 24%;">▲ Next.js</span>
      <span class="float-tag ftag-svelte" style="--delay: 0.4s; --x: 4%; --y: 62%;">🔥 Svelte</span>
      <span class="float-tag ftag-spring" style="--delay: 1.8s; --x: 81%; --y: 66%;">🍃 Spring Boot</span>
      <span class="float-tag ftag-ai" style="--delay: 2.4s; --x: 44%; --y: 87%;">🤖 AI / ML</span>
      <span class="float-tag ftag-fastapi" style="--delay: 0.9s; --x: 88%; --y: 45%;">⚡ FastAPI</span>
      <span class="float-tag ftag-vue" style="--delay: 2.1s; --x: 3%; --y: 44%;">💚 Vue / Nuxt</span>
    </div>
  </section>

  <!-- ====== LOGOS / TRUSTED BY ====== -->
  <section class="trusted section-sm">
    <div class="container">
      <p class="trusted-label reveal">Trusted by growing businesses worldwide</p>
      <div class="trusted-track reveal delay-1">
        <div class="trusted-list">
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item">{name}</span>
          ))}
          {["Clinics", "E-commerce", "SaaS", "Retail", "Agencies", "SMEs", "Startups", "Enterprises"].map(name => (
            <span class="trusted-item" aria-hidden="true">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== WHAT WE DO ====== -->
  <section class="section what-we-do">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">What We Do</span>
        <h2 class="section-title reveal delay-1">
          Full-Stack Digital <span class="gradient-text">Intelligence</span>
        </h2>
        <p class="section-subtitle reveal delay-2">
          We combine strategy, automation, and creative execution to build growth systems that work while you sleep.
        </p>
      </div>

      <div class="services-bento">
        <div class="bento-card bento-large reveal">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2a10 10 0 1 0 10 10M22 2l-5 5M17 2h5v5"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 9V7M12 17v-2M9 12H7M17 12h-2"/>
            </svg>
          </div>
          <h3 class="bento-title">AI Workflow Automation</h3>
          <p class="bento-desc">
            We map your operations, identify bottlenecks, and build intelligent automations that eliminate repetitive work, reduce errors, and scale your capacity — without adding headcount.
          </p>
          <div class="bento-tags">
            <span class="tag">n8n</span>
            <span class="tag">Zapier</span>
            <span class="tag">Custom AI</span>
            <span class="tag">LLMs</span>
          </div>
          <a href="/services" class="bento-link">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="bento-card reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 3v18h18"/>
              <path d="m7 16 4-4 4 4 5-5"/>
            </svg>
          </div>
          <h3 class="bento-title">Campaign Analytics</h3>
          <p class="bento-desc">From raw data to actionable insights — dashboards that tell you exactly where to invest and what's driving growth.</p>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="bento-title">Lead Generation</h3>
          <p class="bento-desc">AI-driven funnels, CRM automation, and targeted outreach systems that consistently deliver qualified leads at scale.</p>
        </div>

        <div class="bento-card bento-wide reveal delay-1">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Commerce</h3>
          <p class="bento-desc">Mobile-optimized Shopify stores built for conversion — from product pages to checkout, every pixel earns its place.</p>
          <div class="bento-tags">
            <span class="tag">Shopify</span>
            <span class="tag">CRO</span>
            <span class="tag">UX/UI</span>
          </div>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="bento-title">Consulting & Strategy</h3>
          <p class="bento-desc">Deep-dive strategy sessions that align your tools, team, and technology with real business outcomes.</p>
        </div>

        <div class="bento-card bento-highlight reveal delay-3">
          <div class="bento-icon bento-icon-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="bento-title">Digital Marketing</h3>
          <p class="bento-desc">SEO, PPC, social media — integrated campaigns that build awareness and convert traffic into revenue.</p>
          <div class="bento-tags">
            <span class="tag">SEO</span>
            <span class="tag">PPC</span>
            <span class="tag">Social</span>
          </div>
        </div>

        <div class="bento-card bento-large bento-ai-ml reveal delay-1">
          <div class="bento-ai-orb"></div>
          <div class="bento-icon bento-icon-glow" style="color:#a855f7">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
            </svg>
          </div>
          <h3 class="bento-title">AI & ML Development</h3>
          <p class="bento-desc">
            From custom LLM fine-tuning to computer vision and predictive models — we build production-grade AI systems that deliver real business intelligence.
          </p>
          <div class="bento-tags">
            <span class="tag" style="color:#a855f7;border-color:rgba(168,85,247,0.3);background:rgba(168,85,247,0.1)">PyTorch</span>
            <span class="tag" style="color:#f97316;border-color:rgba(249,115,22,0.3);background:rgba(249,115,22,0.1)">TensorFlow</span>
            <span class="tag" style="color:#14b8a6;border-color:rgba(20,184,166,0.3);background:rgba(20,184,166,0.1)">LangChain</span>
            <span class="tag" style="color:#f1f5f9;border-color:rgba(241,245,249,0.2);background:rgba(241,245,249,0.06)">OpenAI</span>
          </div>
          <a href="/services" class="bento-link" style="color:#a855f7">
            Build AI →
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="bento-card reveal delay-2">
          <div class="bento-icon" style="color:#f59e0b">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              <path d="M11 8v3m0 3h.01"/>
            </svg>
          </div>
          <h3 class="bento-title">SEO Optimization</h3>
          <p class="bento-desc">Technical SEO, keyword dominance, and content strategy that drives organic traffic compounding month over month.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#f59e0b;border-color:rgba(245,158,11,0.3);background:rgba(245,158,11,0.08)">Technical SEO</span>
            <span class="tag" style="color:#f59e0b;border-color:rgba(245,158,11,0.3);background:rgba(245,158,11,0.08)">Core Web Vitals</span>
          </div>
        </div>

        <div class="bento-card reveal delay-3">
          <div class="bento-icon" style="color:#ec4899">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="m12 20 7-7-7-7"/><path d="M5 20V4"/>
            </svg>
          </div>
          <h3 class="bento-title">Branding & Creative</h3>
          <p class="bento-desc">Logos, brand identity systems, copywriting, and visual storytelling that makes your brand impossible to ignore.</p>
          <div class="bento-tags">
            <span class="tag" style="color:#ec4899;border-color:rgba(236,72,153,0.3);background:rgba(236,72,153,0.08)">Brand Identity</span>
            <span class="tag" style="color:#ec4899;border-color:rgba(236,72,153,0.3);background:rgba(236,72,153,0.08)">Design</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TECH STACK ====== -->
  <section class="section tech-stack-section">
    <div class="ts-bg" aria-hidden="true">
      <div class="ts-orb ts-orb-1"></div>
      <div class="ts-orb ts-orb-2"></div>
      <div class="ts-grid-lines"></div>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow reveal">Our Tech Arsenal</span>
        <h2 class="section-title reveal delay-1">We Build With <span class="gradient-text">The Best</span></h2>
        <p class="section-subtitle reveal delay-2">Full-stack mastery from blazing-fast frontends to resilient APIs and production-grade AI systems.</p>
      </div>

      <!-- Tab Switcher -->
      <div class="ts-tabs reveal delay-2">
        <button class="ts-tab active" data-tab="frontend">
          <span>⚛</span> Frontend
        </button>
        <button class="ts-tab" data-tab="backend">
          <span>⚙</span> Backend
        </button>
        <button class="ts-tab" data-tab="ai">
          <span>🧠</span> AI & ML
        </button>
      </div>

      <!-- Panels -->
      <div class="ts-panels">

        <!-- FRONTEND PANEL -->
        <div class="ts-panel ts-panel-active" id="panel-frontend">
          <div class="ts-panel-inner">
            <div class="ts-tech-grid">
              <div class="ts-tech-card reveal delay-1" style="--tc:#61dafb">
                <div class="ts-tech-glyph" style="background:rgba(97,218,251,0.08);border-color:rgba(97,218,251,0.2)">
                  <span style="color:#61dafb;font-size:1.6rem">⚛</span>
                </div>
                <div class="ts-tech-name">React</div>
                <div class="ts-tech-sub">UI Library</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:95%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-2" style="--tc:#fff">
                <div class="ts-tech-glyph" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.15)">
                  <span style="color:#fff;font-size:1.4rem;font-weight:900">▲</span>
                </div>
                <div class="ts-tech-name">Next.js</div>
                <div class="ts-tech-sub">React Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:93%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-3" style="--tc:#4fc08d">
                <div class="ts-tech-glyph" style="background:rgba(79,192,141,0.08);border-color:rgba(79,192,141,0.2)">
                  <span style="color:#4fc08d;font-size:1.4rem">◆</span>
                </div>
                <div class="ts-tech-name">Vue</div>
                <div class="ts-tech-sub">Progressive Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:88%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-4" style="--tc:#00dc82">
                <div class="ts-tech-glyph" style="background:rgba(0,220,130,0.08);border-color:rgba(0,220,130,0.2)">
                  <span style="color:#00dc82;font-size:1.3rem;font-weight:700">N</span>
                </div>
                <div class="ts-tech-name">Nuxt</div>
                <div class="ts-tech-sub">Vue Meta-Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:85%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-5" style="--tc:#ff3e00">
                <div class="ts-tech-glyph" style="background:rgba(255,62,0,0.08);border-color:rgba(255,62,0,0.2)">
                  <span style="color:#ff3e00;font-size:1.3rem">🔥</span>
                </div>
                <div class="ts-tech-name">Svelte</div>
                <div class="ts-tech-sub">Compiled Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:82%"></div></div>
              </div>
            </div>
            <div class="ts-terminal">
              <div class="ts-term-header">
                <span class="ts-term-dot" style="background:#ff5f57"></span>
                <span class="ts-term-dot" style="background:#febc2e"></span>
                <span class="ts-term-dot" style="background:#28c840"></span>
                <span class="ts-term-title">raretree ~ frontend</span>
              </div>
              <div class="ts-term-body" id="ts-term-frontend">
                <div class="ts-term-line"><span class="ts-t-prompt">$</span> <span class="ts-t-cmd">npx create-next-app@latest my-app</span></div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Installing dependencies...</div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Setting up TypeScript config</div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Configuring Tailwind CSS</div>
                <div class="ts-term-line"><span class="ts-t-prompt">$</span> <span class="ts-t-cmd">npm run dev</span></div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-teal">▲</span> Next.js 15.0 ready on <span class="ts-t-teal">http://localhost:3000</span></div>
                <div class="ts-term-line ts-term-out ts-blink">▮</div>
              </div>
            </div>
          </div>
        </div>

        <!-- BACKEND PANEL -->
        <div class="ts-panel" id="panel-backend">
          <div class="ts-panel-inner">
            <div class="ts-tech-grid">
              <div class="ts-tech-card reveal delay-1" style="--tc:#6db33f">
                <div class="ts-tech-glyph" style="background:rgba(109,179,63,0.08);border-color:rgba(109,179,63,0.2)">
                  <span style="color:#6db33f;font-size:1.3rem">🍃</span>
                </div>
                <div class="ts-tech-name">Spring Boot</div>
                <div class="ts-tech-sub">Java Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:90%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-2" style="--tc:#059669">
                <div class="ts-tech-glyph" style="background:rgba(5,150,105,0.08);border-color:rgba(5,150,105,0.2)">
                  <span style="color:#059669;font-size:1.3rem">⚡</span>
                </div>
                <div class="ts-tech-name">FastAPI</div>
                <div class="ts-tech-sub">Python API</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:92%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-3" style="--tc:#00acd7">
                <div class="ts-tech-glyph" style="background:rgba(0,172,215,0.08);border-color:rgba(0,172,215,0.2)">
                  <span style="color:#00acd7;font-size:1.3rem;font-weight:900">Go</span>
                </div>
                <div class="ts-tech-name">Gin</div>
                <div class="ts-tech-sub">Go HTTP Framework</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:85%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-4" style="--tc:#a855f7">
                <div class="ts-tech-glyph" style="background:rgba(168,85,247,0.08);border-color:rgba(168,85,247,0.2)">
                  <span style="color:#a855f7;font-size:1.2rem;font-weight:700">E</span>
                </div>
                <div class="ts-tech-name">Elysia</div>
                <div class="ts-tech-sub">Bun-native API</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:80%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-5" style="--tc:#f97316">
                <div class="ts-tech-glyph" style="background:rgba(249,115,22,0.08);border-color:rgba(249,115,22,0.2)">
                  <span style="color:#f97316;font-size:1.2rem;font-weight:700">H</span>
                </div>
                <div class="ts-tech-name">Hono</div>
                <div class="ts-tech-sub">Edge-native API</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:83%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-6" style="--tc:#68a063">
                <div class="ts-tech-glyph" style="background:rgba(104,160,99,0.08);border-color:rgba(104,160,99,0.2)">
                  <span style="color:#68a063;font-size:1.1rem;font-weight:700">Ex</span>
                </div>
                <div class="ts-tech-name">Express</div>
                <div class="ts-tech-sub">Node.js Server</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:94%"></div></div>
              </div>
            </div>
            <div class="ts-terminal">
              <div class="ts-term-header">
                <span class="ts-term-dot" style="background:#ff5f57"></span>
                <span class="ts-term-dot" style="background:#febc2e"></span>
                <span class="ts-term-dot" style="background:#28c840"></span>
                <span class="ts-term-title">raretree ~ backend</span>
              </div>
              <div class="ts-term-body">
                <div class="ts-term-line"><span class="ts-t-prompt">$</span> <span class="ts-t-cmd">bun create elysia my-api</span></div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Scaffolding Elysia app...</div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Setting up Swagger docs</div>
                <div class="ts-term-line"><span class="ts-t-prompt">$</span> <span class="ts-t-cmd">bun run dev</span></div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-purple">♦</span> Elysia running at <span class="ts-t-purple">:3000</span></div>
                <div class="ts-term-line ts-term-out"><span class="ts-t-green">✓</span> Type-safe API ready</div>
                <div class="ts-term-line ts-term-out ts-blink">▮</div>
              </div>
            </div>
          </div>
        </div>

        <!-- AI & ML PANEL -->
        <div class="ts-panel" id="panel-ai">
          <div class="ts-panel-inner">
            <div class="ts-tech-grid">
              <div class="ts-tech-card reveal delay-1" style="--tc:#ee4c2c">
                <div class="ts-tech-glyph" style="background:rgba(238,76,44,0.08);border-color:rgba(238,76,44,0.2)">
                  <span style="color:#ee4c2c;font-size:1.3rem">🔥</span>
                </div>
                <div class="ts-tech-name">PyTorch</div>
                <div class="ts-tech-sub">Deep Learning</div>
                <div class="ts-tech-bar"><div class="ts-tech-fill" style="--w:90%"></div></div>
              </div>
              <div class="ts-tech-card reveal delay-2" style="--tc:#ff6f00">
                <div class="ts-tech-glyph" style="background:rgba(255,111,0,0.08);border-color:rgba(255,111,0,0.2)">
                  <span style="color:#ff6f00;font-size:1.1rem;font-weight:700">TF</span>
                </div>
                <div class="ts-tech-name">TensorFlow</div>
                <div class="ts-tech-sub">ML Platform</div>

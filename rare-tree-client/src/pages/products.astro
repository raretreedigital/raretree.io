---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Products — Meal Tree, Table Serve & More | Raretree Digital"
  description="Software products built by Raretree Digital: Meal Tree (digital mess & food subscription management) and Table Serve (NFC-based restaurant table ordering & booking system for UAE and global restaurants). Purpose-built, mobile-first, and production-ready."
  keywords="Meal Tree app, meal subscription software, Table Serve, NFC restaurant ordering system, NFC table booking UAE, restaurant NFC menu system, contactless restaurant ordering, QR NFC restaurant app, restaurant booking system UAE, restaurant management software, NFC smart menu, table ordering app, restaurant tech UAE, Raretree products, Raretree Digital products, digital SaaS products"
  url="https://raretree.io/products/"
>

  <!-- PAGE HERO -->
  <section class="products-hero">
    <div class="ph-orb ph-orb-1"></div>
    <div class="ph-orb ph-orb-2"></div>
    <div class="container">
      <div class="ph-inner">
        <span class="section-eyebrow reveal">Built by Raretree</span>
        <h1 class="ph-title reveal delay-1">
          Products That Solve<br/>
          <span class="gradient-text">Real Problems</span>
        </h1>
        <p class="ph-sub reveal delay-2">
          Beyond client work, we build software products — purposeful, well-engineered tools drawn from real industry gaps we've seen up close. Every product ships with the same obsessive attention to UX and reliability we bring to every engagement.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== MEAL TREE ====== -->
  <section class="section product-section">
    <div class="container">

      <!-- Product header -->
      <div class="product-eyebrow-row reveal">
        <span class="product-number">01</span>
        <span class="product-status">
          <span class="status-dot"></span>
          Live &amp; Deployed
        </span>
      </div>

      <div class="product-layout">

        <!-- Left: Info -->
        <div class="product-info reveal-left">
          <div class="product-logo-row">
            <div class="product-icon-wrap">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
                <circle cx="20" cy="20" r="20" fill="rgba(6,214,196,0.12)"/>
                <path d="M20 8c-5.5 0-9 4-9 9 0 3.2 1.8 6.1 4.5 7.7V28a1.5 1.5 0 0 0 1.5 1.5h6A1.5 1.5 0 0 0 24.5 28v-3.3C27.2 23.1 29 20.2 29 17c0-5-3.5-9-9-9z" stroke="#06d6c4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17 32h6" stroke="#06d6c4" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2 class="product-name">Meal Tree</h2>
              <p class="product-category">Mess &amp; Food Subscription Management</p>
            </div>
          </div>

          <p class="product-tagline">
            The <span class="highlight-teal">operating system for mess owners</span> — one platform to manage every subscriber, every meal, every day.
          </p>

          <p class="product-desc">
            Running a mess is deceptively complex. Dozens — sometimes hundreds — of subscribers, each with different meal plans, dietary preferences, and payment cycles. Menu changes ripple into confusion. Complaints get lost in WhatsApp threads. Tracking who paid, who paused, who cancelled is a spreadsheet nightmare.
          </p>
          <p class="product-desc">
            Meal Tree fixes all of it. We built a full-stack platform that gives mess owners a clean command centre to manage their entire operation, and gives subscribers a seamless app experience — including real-time meal notifications, intuitive subscription controls, and a direct support line.
          </p>

          <div class="product-tags">
            <span class="ptag">React Native</span>
            <span class="ptag">Spring Boot</span>
            <span class="ptag">PostgreSQL</span>
            <span class="ptag">Firebase</span>
            <span class="ptag">Push Notifications</span>
          </div>

          <a href="/contact" class="btn btn-primary product-cta">
            Get Meal Tree for Your Mess
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Right: Feature cards -->
        <div class="product-features reveal-right delay-1">

          <div class="pf-card pf-card-accent">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M18 20V10M12 20V4M6 20v-6"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Subscription Dashboard</h4>
              <p class="pf-desc">See every active, paused, and expired subscriber at a glance. Filter by plan, payment status, or join date. Bulk-action overdue accounts in seconds.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Instant Meal Notifications</h4>
              <p class="pf-desc">Change tomorrow's menu? One tap pushes a branded push notification to every subscriber. No more missed updates, no more customer calls asking "what's for lunch?"</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                <line x1="1" y1="10" x2="23" y2="10"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Smart Billing & Renewals</h4>
              <p class="pf-desc">Automated renewal reminders, flexible monthly & weekly plans, and a clean payment history per subscriber. Reduce churn before it happens.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">In-App Support Chat</h4>
              <p class="pf-desc">Subscribers raise meal queries, report issues, or request changes directly in the app. Owners respond from the dashboard. Every conversation is logged and searchable.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">End-to-End Meal Tracking</h4>
              <p class="pf-desc">Track meal delivery status in real time — from kitchen prep to doorstep. Subscribers get live updates; owners see a full delivery log per day.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Operations Analytics</h4>
              <p class="pf-desc">Daily meal count, subscriber growth trends, revenue breakdowns, and menu popularity scores — all in one live dashboard. No spreadsheets required.</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Stats row -->
      <div class="product-stats reveal delay-2">
        <div class="ps-item">
          <span class="ps-num">100%</span>
          <span class="ps-label">Paperless Operations</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">Real-time</span>
          <span class="ps-label">Meal & Delivery Tracking</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">0 calls</span>
          <span class="ps-label">Needed for Menu Updates</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">iOS + Android</span>
          <span class="ps-label">Subscriber App</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ====== TABLE SERVE ====== -->
  <section class="section product-section product-section-alt">
    <div class="container">

      <div class="product-eyebrow-row reveal">
        <span class="product-number">02</span>
        <span class="product-status">
          <span class="status-dot status-dot-amber"></span>
          In Development
        </span>
      </div>

      <div class="product-layout">

        <!-- Left: Info -->
        <div class="product-info reveal-left">
          <div class="product-logo-row">
            <div class="product-icon-wrap product-icon-wrap-amber">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
                <circle cx="20" cy="20" r="20" fill="rgba(245,158,11,0.12)"/>
                <rect x="12" y="8" width="16" height="20" rx="3" stroke="#f59e0b" stroke-width="1.5"/>
                <path d="M16 14h8M16 18h8M16 22h5" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M20 28v4M17 32h6" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="28" cy="10" r="5" fill="rgba(245,158,11,0.15)" stroke="#f59e0b" stroke-width="1.2"/>
                <path d="M26 10h4M28 8v4" stroke="#f59e0b" stroke-width="1" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2 class="product-name">Table Serve</h2>
              <p class="product-category">NFC-Based Restaurant Ordering &amp; Booking System</p>
            </div>
          </div>

          <p class="product-tagline">
            Tap. Order. Done. — <span class="highlight-amber">The smartest table in the restaurant</span> is the one with a Table Serve NFC tag on it.
          </p>

          <p class="product-desc">
            Restaurants in the UAE and beyond are drowning in friction: customers waiting to flag a waiter, orders getting mixed up, menus that need reprinting every week, and reservations managed on whiteboards. Table Serve eliminates all of it with a single NFC tap.
          </p>
          <p class="product-desc">
            Each table gets a sleek NFC tag. Customers tap their phone — no app download required — and instantly access a dynamic digital menu, place orders directly to the kitchen, call for service, and pay at the table. Managers get a real-time dashboard of every order, table status, and revenue metric. We built this for UAE restaurants but it works everywhere.
          </p>

          <div class="product-tags">
            <span class="ptag ptag-amber">NFC Technology</span>
            <span class="ptag ptag-amber">React Native</span>
            <span class="ptag ptag-amber">Node.js</span>
            <span class="ptag ptag-amber">Real-time Orders</span>
            <span class="ptag ptag-amber">UAE &amp; Global</span>
          </div>

          <a href="https://calendly.com/raretreedigital/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary-amber product-cta">
            Get Table Serve for Your Restaurant
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Right: Feature cards -->
        <div class="product-features reveal-right delay-1">

          <div class="pf-card pf-card-amber">
            <div class="pf-icon pf-icon-amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">NFC Tap-to-Order</h4>
              <p class="pf-desc">Customers tap any NFC-enabled phone on the table tag — no app download, no QR code scanning friction. Instant digital menu with full item details, photos, and allergen info.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon pf-icon-amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Live Kitchen Dashboard</h4>
              <p class="pf-desc">Orders fire directly to the kitchen display the moment a customer submits. Chefs see table number, order details, and elapsed time — zero miscommunication, faster service.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon pf-icon-amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <rect x="1" y="4" width="22" height="16" rx="2"/>
                <line x1="1" y1="10" x2="23" y2="10"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Table Booking &amp; Reservations</h4>
              <p class="pf-desc">Guests book tables online or via the NFC tag. Managers manage capacity, set time slots, send confirmation messages, and track no-shows — all from one dashboard.</p>
            </div>
          </div>

          <div class="pf-card">
            <div class="pf-icon pf-icon-amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 5-5"/>
              </svg>
            </div>
            <div>
              <h4 class="pf-title">Revenue &amp; Analytics</h4>
              <p class="pf-desc">Real-time revenue tracking, best-selling item analytics, peak hour reports, and table turnover rates — everything a restaurant owner needs to make smarter decisions.</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Stats row -->
      <div class="product-stats reveal delay-2">
        <div class="ps-item">
          <span class="ps-num">0 App</span>
          <span class="ps-label">Download Required</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">&lt;2 sec</span>
          <span class="ps-label">Tap-to-Menu Speed</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">Real-time</span>
          <span class="ps-label">Kitchen Order Feed</span>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-item">
          <span class="ps-num">UAE &amp; Global</span>
          <span class="ps-label">Multi-region Ready</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ====== MORE COMING ====== -->
  <section class="section-sm coming-soon-section">
    <div class="container">
      <div class="coming-soon-inner reveal-scale">
        <div class="cs-glow"></div>
        <div class="cs-badge">
          <span class="cs-badge-dot"></span>
          More products in the pipeline
        </div>
        <h2 class="cs-title">We're Always Building</h2>
        <p class="cs-sub">Got a real-world problem that needs a purpose-built tool? We'd love to build it together — or hear what you're working on.</p>
        <a href="/contact" class="btn btn-primary btn-lg">
          Let's Talk
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== HERO ===== */
  .products-hero {
    padding: 130px 0 90px;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .ph-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    opacity: 0.22;
  }

  .ph-orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #06d6c4, transparent 70%);
    top: -120px; left: -100px;
    animation: floatOrb 9s ease-in-out infinite;
  }

  .ph-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #a855f7, transparent 70%);
    bottom: -80px; right: -80px;
    animation: floatOrb 12s ease-in-out infinite reverse;
  }

  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-28px) scale(1.06); }
  }

  .ph-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .ph-title {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    color: var(--text);
    margin-bottom: 22px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .ph-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ===== PRODUCT SECTION ===== */
  .product-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 48px;
  }

  .product-number {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, rgba(6,214,196,0.25), rgba(168,85,247,0.1));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.04em;
    user-select: none;
  }

  .product-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(6,214,196,0.08);
    border: 1px solid rgba(6,214,196,0.25);
    color: #00f5e4;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
  }

  .status-dot {
    width: 7px; height: 7px;
    background: #00f5e4;
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(0,245,228,0.7);
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.7); opacity: 0.5; }
  }

  /* ===== PRODUCT LAYOUT ===== */
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 64px;
  }

  .product-logo-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .product-icon-wrap {
    width: 60px; height: 60px;
    background: rgba(6,214,196,0.08);
    border: 1px solid rgba(6,214,196,0.22);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .product-name {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 6px;
  }

  .product-category {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .product-tagline {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  .highlight-teal {
    color: #00f5e4;
    background: rgba(6,214,196,0.08);
    border-radius: 4px;
    padding: 0 4px;
  }

  .product-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 24px 0 32px;
  }

  .ptag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-subtle);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 5px 13px;
    border-radius: 100px;
  }

  .product-cta {
    display: inline-flex;
  }

  /* ===== FEATURE CARDS ===== */
  .product-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .pf-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .pf-card:hover {
    border-color: var(--border-accent-2);
    background: var(--bg-elevated);
    transform: translateY(-3px);
    box-shadow: var(--shadow-elevated);
  }

  .pf-card-accent {
    grid-column: span 2;
    border-color: var(--border-accent-2);
    background: linear-gradient(135deg, rgba(6,214,196,0.07) 0%, var(--bg-card) 100%);
  }

  .pf-icon {
    width: 40px; height: 40px;
    background: rgba(6,214,196,0.1);
    border: 1px solid rgba(6,214,196,0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #00f5e4;
    flex-shrink: 0;
  }

  .pf-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .pf-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ===== PRODUCT STATS ===== */
  .product-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    padding: 36px 48px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    backdrop-filter: blur(12px);
    flex-wrap: wrap;
  }

  .ps-item {
    text-align: center;
  }

  .ps-num {
    display: block;
    font-size: 1.35rem;
    font-weight: 800;
    background: linear-gradient(135deg, #00f5e4, #06d6c4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .ps-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ps-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* ===== COMING SOON ===== */
  .coming-soon-section {
    position: relative;
  }

  .coming-soon-inner {
    position: relative;
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 28px;
    padding: 80px 48px;
    overflow: hidden;
    backdrop-filter: blur(16px);
    max-width: 680px;
    margin: 0 auto;
  }

  .cs-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(6,214,196,0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .cs-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(168,85,247,0.1);
    border: 1px solid rgba(168,85,247,0.25);
    color: #c084fc;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
    position: relative;
  }

  .cs-badge-dot {
    width: 7px; height: 7px;
    background: #a855f7;
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(168,85,247,0.7);
    animation: statusPulse 2.4s ease-in-out infinite;
  }

  .cs-title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    color: var(--text);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    position: relative;
  }

  .cs-sub {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .product-layout { grid-template-columns: 1fr; gap: 40px; }
  }

  @media (max-width: 640px) {
    .product-features { grid-template-columns: 1fr; }
    .pf-card-accent { grid-column: span 1; }
    .product-stats { gap: 24px; padding: 28px 24px; }
    .ps-divider { display: none; }
    .coming-soon-inner { padding: 48px 28px; }
  }

  /* 3D support */
  .pf-card {
    transform-style: preserve-3d;
    will-change: transform;
  }
  .product-info, .product-features {
    will-change: transform;
  }
  .product-icon-wrap {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ===== TABLE SERVE — AMBER THEME ===== */
  .product-section-alt {
    background: radial-gradient(ellipse at 80% 50%, rgba(245,158,11,0.04) 0%, transparent 60%);
  }

  .status-dot-amber {
    width: 7px; height: 7px;
    background: #f59e0b;
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(245,158,11,0.7);
    animation: statusPulse 2s ease-in-out infinite;
  }

  .product-icon-wrap-amber {
    background: rgba(245,158,11,0.08);
    border-color: rgba(245,158,11,0.22);
  }

  .highlight-amber {
    color: #f59e0b;
    background: rgba(245,158,11,0.08);
    border-radius: 4px;
    padding: 0 4px;
  }

  .ptag-amber {
    color: #f59e0b;
    border-color: rgba(245,158,11,0.3);
    background: rgba(245,158,11,0.07);
  }

  .pf-card-amber {
    grid-column: span 2;
    border-color: rgba(245,158,11,0.3);
    background: linear-gradient(135deg, rgba(245,158,11,0.07) 0%, var(--bg-card) 100%);
  }

  .pf-icon-amber {
    background: rgba(245,158,11,0.1);
    border-color: rgba(245,158,11,0.2);
    color: #f59e0b;
  }

  .btn-primary-amber {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: #0a0a0f;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 28px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(245,158,11,0.3);
  }

  .btn-primary-amber:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(245,158,11,0.45);
  }
</style>

<script is:inline>
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  /* ─ Word fly-in ─ */
  document.querySelectorAll('.ph-title, .cs-title').forEach(title => {
    if (title.dataset.splitDone) return;
    title.dataset.splitDone = 'true';
    Array.from(title.childNodes).forEach(node => {
      if (node.nodeType !== Node.TEXT_NODE) return;
      const raw = node.textContent;
      const words = raw.trim().split(/\s+/).filter(Boolean);
      if (!words.length) return;
      const hadLeading  = /^\s/.test(raw);
      const hadTrailing = /\s$/.test(raw);
      const frag = document.createDocumentFragment();
      if (hadLeading) frag.appendChild(document.createTextNode(' '));
      words.forEach((w, idx) => {
        const outer = document.createElement('span');
        outer.style.cssText = 'display:inline-block;overflow:hidden;vertical-align:bottom;';
        const inner = document.createElement('span');
        inner.className = 'gsap-word'; inner.style.display = 'inline-block';
        inner.textContent = w; outer.appendChild(inner); frag.appendChild(outer);
        if (idx < words.length - 1) frag.appendChild(document.createTextNode(' '));
      });
      if (hadTrailing) frag.appendChild(document.createTextNode(' '));
      title.replaceChild(frag, node);
    });
    title.querySelectorAll('.gradient-text').forEach(gt => {
      const words = gt.textContent.trim().split(/\s+/).filter(Boolean);
      gt.innerHTML = words.map(w =>
        `<span style="display:inline-block;overflow:hidden;vertical-align:bottom;"><span class="gsap-word" style="display:inline-block;">${w}</span></span>`
      ).join(' ');
    });
    ScrollTrigger.create({
      trigger: title, start: 'top 93%', once: true,
      onEnter: () => gsap.fromTo(title.querySelectorAll('.gsap-word'),
        { y: '105%', opacity: 0 },
        { y: '0%', opacity: 1, duration: 0.42, stagger: 0.03, ease: 'power3.out', clearProps: 'all' }
      ),
    });
  });

  /* ─ Subtitle / sub reveal ─ */
  document.querySelectorAll('.ph-sub, .cs-sub').forEach(el => {
    gsap.set(el, { autoAlpha: 0, y: 14, filter: 'blur(8px)' });
    ScrollTrigger.create({
      trigger: el, start: 'top 95%', once: true,
      onEnter: () => gsap.to(el, { autoAlpha: 1, y: 0, filter: 'blur(0px)', duration: 0.48, ease: 'power3.out', clearProps: 'all' }),
    });
  });

  /* ─ Product info slide in from left ─ */
  const pInfo = document.querySelector('.product-info');
  if (pInfo) {
    gsap.set(pInfo, { autoAlpha: 0, x: -60, rotationY: 15 });
    ScrollTrigger.create({
      trigger: pInfo, start: 'top 85%', once: true,
      onEnter: () => gsap.to(pInfo, { autoAlpha: 1, x: 0, rotationY: 0, duration: 0.7, ease: 'power3.out', clearProps: 'all' }),
    });
  }

  /* ─ Feature cards 3D entrance + hover tilt ─ */
  const pfCards = Array.from(document.querySelectorAll('.pf-card'));
  gsap.set(pfCards, { autoAlpha: 0, y: 36, rotationX: 24 });
  ScrollTrigger.create({
    trigger: '.product-features', start: 'top 85%', once: true,
    onEnter: () => gsap.to(pfCards, {
      autoAlpha: 1, y: 0, rotationX: 0,
      stagger: { amount: 0.45, from: 'start' },
      duration: 0.52, ease: 'back.out(1.6)', clearProps: 'transform,opacity,visibility',
    }),
  });
  pfCards.forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const nx = (e.clientX - r.left) / r.width - 0.5, ny = (e.clientY - r.top) / r.height - 0.5;
      gsap.to(card, { rotationY: nx * 14, rotationX: -ny * 11, scale: 1.02, transformPerspective: 700, duration: 0.22, ease: 'power2.out', overwrite: 'auto' });
      const icon = card.querySelector('.pf-icon');
      if (icon) gsap.to(icon, { x: nx * 8, y: ny * 6, scale: 1.12, duration: 0.22, ease: 'power2.out', overwrite: 'auto' });
    });
    card.addEventListener('mouseleave', () => {
      gsap.to(card, { rotationY: 0, rotationX: 0, scale: 1, duration: 0.6, ease: 'elastic.out(1, 0.5)', overwrite: 'auto' });
      const icon = card.querySelector('.pf-icon');
      if (icon) gsap.to(icon, { x: 0, y: 0, scale: 1, duration: 0.6, ease: 'elastic.out(1, 0.5)', overwrite: 'auto' });
    });
  });

  /* ─ Product stats counter animation ─ */
  const statsRow = document.querySelector('.product-stats');
  if (statsRow) {
    gsap.set(statsRow, { autoAlpha: 0, y: 28 });
    ScrollTrigger.create({
      trigger: statsRow, start: 'top 88%', once: true,
      onEnter: () => gsap.to(statsRow, {
        autoAlpha: 1, y: 0, duration: 0.55, ease: 'back.out(1.8)', clearProps: 'all',
        onComplete: () => {
          /* Elastic number bounce */
          document.querySelectorAll('.ps-item').forEach((item, i) => {
            gsap.fromTo(item, { scale: 0.75, autoAlpha: 0 }, { scale: 1, autoAlpha: 1, duration: 0.5, delay: i * 0.1, ease: 'back.out(2.5)', clearProps: 'all' });
          });
        }
      }),
    });
  }

  /* ─ Product eyebrow row reveal ─ */
  const eyebrow = document.querySelector('.product-eyebrow-row');
  if (eyebrow) {
    gsap.set(eyebrow, { autoAlpha: 0, x: -30 });
    ScrollTrigger.create({
      trigger: eyebrow, start: 'top 90%', once: true,
      onEnter: () => gsap.to(eyebrow, { autoAlpha: 1, x: 0, duration: 0.5, ease: 'power3.out', clearProps: 'all' }),
    });
  }

  /* ─ Product icon 3D spin on hover ─ */
  const iconWrap = document.querySelector('.product-icon-wrap');
  if (iconWrap) {
    iconWrap.addEventListener('mouseenter', () =>
      gsap.to(iconWrap, { rotationY: 360, duration: 0.7, ease: 'power2.inOut', overwrite: 'auto',
        onComplete: () => gsap.set(iconWrap, { rotationY: 0 }) })
    );
  }

  /* ─ Coming soon box pop + float ─ */
  const csBox = document.querySelector('.coming-soon-inner');
  if (csBox) {
    gsap.set(csBox, { autoAlpha: 0, scale: 0.88, y: 32 });
    ScrollTrigger.create({
      trigger: csBox, start: 'top 88%', once: true,
      onEnter: () => gsap.to(csBox, {
        autoAlpha: 1, scale: 1, y: 0, duration: 0.65, ease: 'back.out(2)', clearProps: 'transform,opacity,visibility',
        onComplete: () => gsap.to(csBox, { y: -10, duration: 3, ease: 'sine.inOut', yoyo: true, repeat: -1 }),
      }),
    });
    csBox.addEventListener('mousemove', e => {
      const r = csBox.getBoundingClientRect();
      const nx = (e.clientX - r.left) / r.width - 0.5, ny = (e.clientY - r.top) / r.height - 0.5;
      gsap.to(csBox, { rotationY: nx * 10, rotationX: -ny * 7, transformPerspective: 900, duration: 0.25, ease: 'power2.out', overwrite: 'auto' });
    });
    csBox.addEventListener('mouseleave', () => gsap.to(csBox, { rotationY: 0, rotationX: 0, duration: 0.7, ease: 'elastic.out(1, 0.5)', overwrite: 'auto' }));
  }

  /* ─ Feature right panel 3D slide in ─ */
  const pFeat = document.querySelector('.product-features');
  if (pFeat) {
    gsap.set(pFeat, { autoAlpha: 0, x: 60, rotationY: -15 });
    ScrollTrigger.create({
      trigger: pFeat, start: 'top 85%', once: true,
      onEnter: () => gsap.to(pFeat, { autoAlpha: 1, x: 0, rotationY: 0, duration: 0.7, ease: 'power3.out', clearProps: 'all' }),
    });
  }
})();
</script>

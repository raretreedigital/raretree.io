---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  keywords?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = "Raretree Digital — full-stack digital agency for AI automation, CRM/ERP implementation (Zoho, Salesforce, HubSpot, Odoo), WhatsApp Business API, full-stack web & mobile development, SEO, and growth marketing.",
  image = "/og-image.png",
  url = Astro.url.href,
  keywords = "Raretree Digital, Raretree, AI automation, digital transformation, Zoho CRM, Zoho Books, Zoho Desk, Zoho People, Zoho Projects, Salesforce CRM, HubSpot CRM, Odoo ERP, Microsoft Dynamics, WhatsApp Business API, full-stack development, React, Node.js, Flutter, SEO, digital marketing, growth marketing",
  type = "website",
  noindex = false,
} = Astro.props;

const siteUrl = "https://raretree.io";
const canonicalUrl = url.startsWith("http") ? url : siteUrl + url;
const ogImage = image.startsWith("http") ? image : siteUrl + image;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Raretree Digital",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo.png`,
        "width": 200,
        "height": 200,
      },
      "sameAs": [
        "https://www.linkedin.com/company/raretree"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "contact@raretree.io",
        "availableLanguage": "English"
      },
      "description": "Raretree Digital is a full-stack digital agency specialising in AI automation, CRM/ERP implementation (Zoho, Salesforce, HubSpot, Odoo), WhatsApp Business API, full-stack web & mobile development, SEO, and data-driven growth marketing.",
      "areaServed": "Worldwide",
      "serviceType": [
        "AI Automation", "Workflow Automation", "Digital Transformation",
        "Full-Stack Web Development", "React Development", "Node.js Development", "Next.js Development",
        "Mobile App Development", "Flutter App Development", "React Native Development",
        "Zoho CRM Implementation", "Zoho Books", "Zoho Desk", "Zoho People", "Zoho Projects", "Zoho Campaigns", "Zoho Analytics",
        "Salesforce CRM Implementation", "Salesforce Sales Cloud", "Salesforce Service Cloud",
        "HubSpot CRM Implementation", "HubSpot Marketing Hub",
        "Odoo ERP Implementation", "Odoo Full Stack", "Odoo Accounting", "Odoo Inventory",
        "Microsoft Dynamics 365", "Pipedrive CRM",
        "WhatsApp Business API Automation", "WhatsApp Chatbot",
        "Digital Marketing", "SEO", "SEM", "Growth Marketing", "Email Marketing", "Branding"
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Raretree Digital",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?s={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      "url": canonicalUrl,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "about": { "@id": `${siteUrl}/#organization` },
      "inLanguage": "en-US"
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Canonical & Indexing -->
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- DNS Prefetch for external resources -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <!-- Primary Meta -->
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Raretree Digital" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Raretree Digital" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@raretree_io" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- GSAP Animation Engine (deferred — non-blocking) -->
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

    <!-- Anti-FOUC: apply saved theme before paint -->
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.05, rootMargin: '0px 0px 60px 0px' }
      );
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale')
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  main {
    padding-top: 72px;
    min-height: calc(100vh - 72px);
  }
  html, body {
    margin: 0;
    width: 100%;
  }
</style>

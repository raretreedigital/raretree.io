---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <Image src={logo} alt="Raretree" class="footer-logo-img" width={180} height={60} />
        </a>
        <p class="footer-tagline">
          AI Automation &amp; Digital Transformation for businesses that want to scale intelligently.
        </p>
        <div class="footer-social">
          <div class="footer-social-label">Follow us</div>
          <a
            href="https://www.linkedin.com/company/raretree-digital/?viewAsMember=true"
            target="_blank"
            rel="noopener"
            class="social-link social-linkedin"
            aria-label="LinkedIn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="social-link-label">LinkedIn</span>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links">
          <li><a href="/services">AI & ML Development</a></li>
          <li><a href="/services">AI Automation</a></li>
          <li><a href="/services">Zoho Implementation</a></li>
          <li><a href="/services">Salesforce CRM</a></li>
          <li><a href="/services">WhatsApp Automation</a></li>
          <li><a href="/services">Odoo ERP</a></li>
          <li><a href="/services">Digital Marketing</a></li>
          <li><a href="/services">SEO Optimization</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-heading">Get In Touch</h4>
        <ul class="footer-links">
          <li>
            <a href="mailto:contact@raretree.io" class="footer-contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m2 7 10 7 10-7"/>
              </svg>
              contact@raretree.io
            </a>
          </li>
          <li>
            <a href="/contact" class="footer-contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
              </svg>
              Book a Strategy Call
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-divider"></div>
      <div class="footer-bottom-content">
        <p class="footer-copy">
          &copy; {currentYear} Raretree Digital. All rights reserved.
        </p>
        <div class="footer-bottom-links">
          <a href="https://raretree.io" class="built-with-tag">raretree.io</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #050b18;
    border-top: 1px solid rgba(148, 163, 184, 0.08);
    padding: 80px 0 0;
    position: relative;
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 200px;
    background: radial-gradient(ellipse, rgba(20, 184, 166, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 60px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
  }

  .footer-social-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #334155;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: rgba(30, 41, 59, 0.6);
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 10px;
    color: #94a3b8;
    transition: all 0.3s ease;
    gap: 0;
    overflow: hidden;
  }

  .social-link-label {
    display: none;
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .social-linkedin {
    background: rgba(10, 102, 194, 0.12);
    border-color: rgba(10, 102, 194, 0.25);
    color: #0a66c2;
    width: auto;
    padding: 0 14px 0 10px;
    gap: 8px;
  }

  .social-linkedin .social-link-label {
    display: block;
    color: #7fb0dc;
  }

  .social-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(10, 102, 194, 0.3);
    border-color: rgba(10, 102, 194, 0.5);
    background: rgba(10, 102, 194, 0.2);
    color: #4d9ed6;
  }

  .social-link:hover .social-link-label {
    color: #f1f5f9;
  }

  .footer-heading {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 20px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: #64748b;
    transition: all 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-links a:hover {
    color: #14b8a6;
    transform: translateX(4px);
  }

  .footer-contact-link {
    display: flex !important;
    align-items: center;
    gap: 8px !important;
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.1), transparent);
    margin-bottom: 28px;
  }

  .footer-bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 32px;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: #475569;
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #475569;
  }

  .built-with-tag {
    padding: 2px 10px;
    background: rgba(20, 184, 166, 0.1);
    color: #14b8a6;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid rgba(20, 184, 166, 0.2);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-bottom-content {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>
